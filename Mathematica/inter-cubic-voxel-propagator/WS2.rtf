   Hmm, I keep getting the algebra tangled.  Let me just\
   separate out the two contributions cleanly.\
*)\
\
(* Clean derivation:\
   P_ijkl = \uc0\u8747  d\'b3k/(2\u960 )\'b3 |\u70 \u771 |\'b2 \u915 \u771 ^\u8734 _ijkl exp(ik\'b7R)\
\
   \uc0\u915 \u771 ^\u8734 _ijkl = -1/(2\u956 )[\u107 \u770 _j\u107 \u770 _l \u948 _ik + \u107 \u770 _i\u107 \u770 _l \u948 _jk - 2\u951  \u107 \u770 _i\u107 \u770 _j\u107 \u770 _k\u107 \u770 _l]\
\
   Define:\
   A_jl(R) = \uc0\u8747  d\'b3k/(2\u960 )\'b3 |\u70 \u771 |\'b2 \u107 \u770 _j\u107 \u770 _l exp(ik\'b7R)\
            = -\uc0\u8706 \'b2[\u934 /(4\u960 )]/\u8706 R_j\u8706 R_l\
\
   B_ijkl(R) = \uc0\u8747  d\'b3k/(2\u960 )\'b3 |\u70 \u771 |\'b2 \u107 \u770 _i\u107 \u770 _j\u107 \u770 _k\u107 \u770 _l exp(ik\'b7R)\
              = \uc0\u8706 \u8308 [\u936 *C]/\u8706 R_i\u8706 R_j\u8706 R_k\u8706 R_l\
              where C is to be determined from FT convention\
\
   Then:\
   P_ijkl = -1/(2\uc0\u956 )[\u948 _ik A_jl + \u948 _jk A_il - 2\u951  B_ijkl]\
*)\
\
(* Compute A_jl numerically *)\
Ajl = Table[D2[\uc0\u934 00, R0, j, l] / (-4 Pi), \{j, 3\}, \{l, 3\}];\
Print["  A matrix (\uc0\u8747  |\u70 \u771 |\'b2 \u107 \u770 _j\u107 \u770 _l exp(ik\'b7R)):"];\
Print["  A = ", MatrixForm[Ajl // Chop], "\\n"];\
\
(* For B_ijkl, we need the 1/k\uc0\u8308  potential.\
   \uc0\u8747  d\'b3k/(2\u960 )\'b3 exp(ik\'b7r)/k\u8308  = |r|/(8\u960 )\
   so \uc0\u8747  |\u70 \u771 |\'b2/k\u8308  exp(ik\'b7R) d\'b3k/(2\u960 )\'b3 = \u936 \u8320 \u8320 (R)/(8\u960 )  ...\
   but wait, need to check: the convolution of |\uc0\u70 \u771 |\'b2 with exp(ik\'b7R)/k\u8308 \
   gives the convolution of the cross-correlation with |r|/(8\uc0\u960 )\
\
   Actually, by the convolution theorem:\
   \uc0\u8747  d\'b3k/(2\u960 )\'b3 |\u70 \u771 \u8320 |\'b2/k\'b2 exp(ik\'b7R) = \u8747  [\u8747 _A d\'b3s][\u8747 _B d\'b3s'] 1/(4\u960 |s-s'+R|)\
   = \uc0\u934 \u8320 \u8320 (R)/(4\u960 )  \u10003 \
\
   \uc0\u8747  d\'b3k/(2\u960 )\'b3 |\u70 \u771 \u8320 |\'b2/k\u8308  exp(ik\'b7R) = \u8747 \u8747  |s-s'+R|/(8\u960 ) d\'b3sd\'b3s'\
                                       ... or -|s-s'+R|/(8\uc0\u960 )?\
   Need to check sign.\
\
   FT of 1/k\'b2 = 4\uc0\u960 /|r|  \u8594   \u8747 (1/k\'b2)exp(ik\'b7r) d\'b3k/(2\u960 )\'b3 = 1/(4\u960 |r|)  \u10003 \
   FT of 1/k\uc0\u8308 :  \u8711 \'b2(1/k\u8308 ) = -1/k\'b2  in FT space\
   In real space: \uc0\u8711 \'b2[FT(1/k\u8308 )] = -1/(4\u960 |r|)\
   We know \uc0\u8711 \'b2|r| = 2/|r|, so FT(1/k\u8308 ) = -|r|/(8\u960 )\
\
   So: \uc0\u8747  |\u70 \u771 |\'b2/k\u8308  exp(ik\'b7R) d\'b3k/(2\u960 )\'b3 = -\u936 \u8320 \u8320 (R)/(8\u960 )   \u8592  NOTE MINUS\
*)\
\
(* Therefore:\
   B_ijkl = \uc0\u8706 \u8308 /\u8706 R_i\u8706 R_j\u8706 R_k\u8706 R_l [-\u936 \u8320 \u8320 /(8\u960 )]\
          = -1/(8\uc0\u960 ) \u8706 \u8308 \u936 \u8320 \u8320 /\u8706 R_i\u8706 R_j\u8706 R_k\u8706 R_l\
*)\
\
