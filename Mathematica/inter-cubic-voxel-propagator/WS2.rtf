\
(* For 1111:\
   \uc0\u915 \u771 ^\u8734 _1111 = -1/(2\u956 )[\u107 \u770 \u8321 \'b2 + \u107 \u770 \u8321 \'b2 - 2\u951  \u107 \u770 \u8321 \u8308 ] = -(1-\u951 )\u107 \u770 \u8321 \'b2/\u956  - ...\
   wait:\
