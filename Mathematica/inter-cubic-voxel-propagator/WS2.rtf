   \uc0\u915 \u771 ^\u8734 _1122 = -1/(2\u956 )[0 + 0 - 2\u951  \u107 \u770 \u8321 \'b2\u107 \u770 \u8322 \'b2]\
            = \uc0\u951  \u107 \u770 \u8321 \'b2\u107 \u770 \u8322 \'b2 / \u956 \
\
   And:\
   P_1122 = (\uc0\u951 /\u956 ) \u8706 \u8308 (-\u936 /(8\u960 ))/\u8706 R\u8321 \'b2\u8706 R\u8322 \'b2\
          = -\uc0\u951 /(8\u960 \u956 ) \u8706 \u8308 \u936 /\u8706 R\u8321 \'b2\u8706 R\u8322 \'b2\
*)\
\
