(* Beginning of Notebook Content *)
Notebook[{

Cell["\<\
CubeT6 Overnight High-Precision Recomputation\
\>", "Title",
 CellChangeTimes->{{3.92, 3.92}}],

Cell[TextData[{
 "Self-contained overnight high-precision recomputation of the 14 nonzero \
orbit representatives of the cube T_27 quad-quad body bilinear block.\n\n",
 StyleBox["Purpose. ", FontWeight->"Bold"],
 "Produces high-precision (~25-30 digit) numerical values for the 3 \
distinct A-scalars and 10 distinct B-scalars that completely determine the \
18x18 quad-quad block B27quad, as documented in cube_galerkin27_results.tex.\
\n\n",
 StyleBox["How to run. ", FontWeight->"Bold"],
 "Open the notebook in Mathematica and choose ",
 StyleBox["Evaluation > Evaluate Notebook",
  FontSlant->"Italic"],
 " (or press Alt+. / Cmd+A then Shift+Enter). All input cells below are \
marked as initialization cells and will run sequentially.  No human \
intervention is required after pressing Evaluate Notebook.\n\n",
 StyleBox["Runtime. ", FontWeight->"Bold"],
 "A few hours at WP=30 thanks to memoization (each master integral is \
computed exactly once then reused across orbits).  Conservatively plan for \
overnight (8-12h).\n\n",
 StyleBox["Checkpointing. ", FontWeight->"Bold"],
 "A checkpoint file CubeT6ScalarValues_HighPrec_checkpoint.wl is written \
after each orbit completes, so partial progress is recoverable if the job \
is interrupted.  The final output is CubeT6ScalarValues_HighPrec.wl.\n\n",
 StyleBox["Output. ", FontWeight->"Bold"],
 "The final .wl file contains cubeT6HighPrecResults (association keyed by \
orbit tag), cubeT6HighPrecAlphas (3 unique nonzero A-scalars), and \
cubeT6HighPrecBetas (10 unique nonzero B-scalars).  These are the inputs \
for PSLQ-style closed-form reconstruction against the 9-component closure \
building blocks (iA, iB11, iB12, K1, K3, ...)."
}], "Text"],

Cell[CellGroupData[{

Cell["0. Header and configuration", "Section"],

Cell["\<\
Print[\"===================================================================\
\"];
Print[\"CubeT6OvernightHighPrec : high-precision scalar recomputation\"];
Print[\"===================================================================\
\"];
Print[\"Start time: \", DateString[]];
Print[];

$here = If[$InputFileName =!= \"\" && $InputFileName =!= $Failed,
  DirectoryName[$InputFileName],
  NotebookDirectory[]];

(* The single knob that controls speed vs. precision.
   WP=30 gives 25+ digits; WP=40 gives 35+ digits but is slower.
   DO NOT go below WP=25 or bbBodyAB loses digits. *)
highWP = 30;

mpPrecisionGoal = highWP - 5;
mpAccuracyGoal  = highWP - 5;
mpMaxRecursion  = 40;

k3PrecisionGoal = highWP - 8;
k3AccuracyGoal  = highWP - 8;
k3MaxRecursion  = 40;

checkpointPath = FileNameJoin[{$here, \"CubeT6ScalarValues_HighPrec_checkpoint.wl\"}];
finalPath      = FileNameJoin[{$here, \"CubeT6ScalarValues_HighPrec.wl\"}];

Print[\"Configuration:\"];
Print[\"  WorkingPrecision    : \", highWP];
Print[\"  Mp  PrecisionGoal   : \", mpPrecisionGoal];
Print[\"  K3  PrecisionGoal   : \", k3PrecisionGoal];
Print[\"  Checkpoint file     : \", checkpointPath];
Print[\"  Final output file   : \", finalPath];
Print[];\
\>", "Input",
 InitializationCell->True]

}, Open]],

Cell[CellGroupData[{

Cell["1. Load cached Tier-6 master integrals (optional)", "Section"],

Cell["\<\
(* CubeT6Masters.wl holds seven exact symbolic closed forms for the
   rank-6/8 all-even high-degree Mp values.  These are primed into the
   Mp cache so the downstream NIntegrate never sees them.  If the file
   is missing we fall back to NIntegrate for those too. *)

mastersPath = FileNameJoin[{$here, \"CubeT6Masters.wl\"}];
If[FileExistsQ[mastersPath],
  Print[\"Loading CubeT6Masters.wl (7 exact symbolic masters) ...\"];
  Get[mastersPath],
  Print[\"WARNING: CubeT6Masters.wl not found; will use NIntegrate for all Mp.\"];
];\
\>", "Input",
 InitializationCell->True]

}, Open]],

Cell[CellGroupData[{

Cell["2. High-precision Mp and K3 definitions", "Section"],

Cell["\<\
ClearAll[Mp, K1at, K3diag, K3off, K3kernel];

(* Cubic symmetry: canonicalize argument order to ASCENDING. *)
Mp[p_Integer, q_Integer, r_Integer] /; ! OrderedQ[{p, q, r}] :=
  Mp @@ Sort[{p, q, r}];

(* Prime high-degree masters from CubeT6Masters.wl if loaded. *)
If[ValueQ[mp222], Mp[2, 2, 2] = mp222];
If[ValueQ[mp420], Mp[0, 2, 4] = mp420];
If[ValueQ[mp600], Mp[0, 0, 6] = mp600];
If[ValueQ[mp422], Mp[2, 2, 4] = mp422];
If[ValueQ[mp440], Mp[0, 4, 4] = mp440];
If[ValueQ[mp620], Mp[0, 2, 6] = mp620];
If[ValueQ[mp800], Mp[0, 0, 8] = mp800];

(* Mp[p,q,r]: HYBRID symbolic Integrate[] with two strategies.
   STRATEGY 1: ITERATED OCTANT (z -> y -> x with Assumptions). Fast
     (~5-15s) and compact for most (p,q,r) including odd-exponent
     cases.  Fails for some all-even high-degree cases (Mp[0,0,4]
     -> Undefined, Mp[0,1,4] -> unevaluated).
   STRATEGY 2: PARTIAL-DOMAIN.  Each dim extended to [-1,1] iff its
     exponent is even (factor 1/2 per such dim).  Slower (~80-300s)
     but reliable for the all-even high-degree cases.
   STRATEGY 3 (last resort): NIntegrate fallback. Should NEVER
     trigger -- contaminates downstream symbolic assembly. *)
Mp[p_Integer, q_Integer, r_Integer] := Mp[p, q, r] = Module[
  {integrand, iterRes, xLo, yLo, zLo, factor, partialRes, result},
  integrand = x^p y^q z^r/Sqrt[x^2 + y^2 + z^2];

  (* Strategy 1: iterated octant *)
  Print[\"  Mp[\", p, \",\", q, \",\", r, \"] iterated z->y->x ...\"];
  iterRes = TimeConstrained[
    Catch[
      Module[{i1, i2, i3},
        i1 = Integrate[integrand, {z, 0, 1},
          Assumptions -> 0 < x < 1 && 0 < y < 1];
        If[!FreeQ[i1, Integrate], Throw[$Failed, \"iter\"]];
        i2 = Integrate[i1, {y, 0, 1}, Assumptions -> 0 < x < 1];
        If[!FreeQ[i2, Integrate], Throw[$Failed, \"iter\"]];
        i3 = Integrate[i2, {x, 0, 1}];
        If[!FreeQ[i3, Integrate], Throw[$Failed, \"iter\"]];
        i3],
      \"iter\"],
    120, $Failed];
  If[iterRes =!= $Failed && FreeQ[iterRes, Integrate]
       && iterRes =!= \"Undefined\" && !MatchQ[iterRes, _Indeterminate],
    Print[\"    -> iter OK (LeafCount=\", LeafCount[iterRes], \")\"];
    Return[iterRes]];

  (* Strategy 2: partial domain *)
  Print[\"    -> iter failed, trying partial domain ...\"];
  xLo = If[EvenQ[p], -1, 0]; factor  = If[EvenQ[p], 1/2, 1];
  yLo = If[EvenQ[q], -1, 0]; factor *= If[EvenQ[q], 1/2, 1];
  zLo = If[EvenQ[r], -1, 0]; factor *= If[EvenQ[r], 1/2, 1];
  Print[\"       box=[\", xLo, \",1]x[\", yLo, \",1]x[\", zLo, \",1] factor=\",
    factor];
  partialRes = TimeConstrained[
    Integrate[integrand, {x, xLo, 1}, {y, yLo, 1}, {z, zLo, 1}],
    600, $Failed];
  If[partialRes =!= $Failed && FreeQ[partialRes, Integrate],
    result = factor * partialRes;
    Print[\"    -> partial OK (LeafCount=\", LeafCount[result], \")\"];
    Return[result]];

  (* Strategy 3: NIntegrate fallback *)
  Print[\"    -> partial domain failed; NIntegrate fallback at WP=\", highWP];
  NIntegrate[integrand, {x, 0, 1}, {y, 0, 1}, {z, 0, 1},
    WorkingPrecision -> highWP,
    PrecisionGoal -> mpPrecisionGoal,
    AccuracyGoal -> mpAccuracyGoal,
    MaxRecursion -> mpMaxRecursion,
    Method -> {\"GlobalAdaptive\",
      \"SingularityHandler\" -> \"DuffyCoordinates\",
      \"MaxErrorIncreases\" -> 20000}]
];

(* ------------------------------------------------------------------ *)
(* PELL-IDENTITY POST-PROCESSING RULES (Section 2b)                   *)
(* ------------------------------------------------------------------ *)
(* Collapse log arguments of the form A +/- B Sqrt[3] or A +/- B Sqrt[2] *)
(* that are powers of the fundamental Pell units:                      *)
(*   (2 + Sqrt[3]) for x^2 - 3 y^2 = 1,                                *)
(*   (3 + 2 Sqrt[2]) for x^2 - 2 y^2 = 1.                              *)
(* Also handle Log[2^m * (A +/- B Sqrt[3])] for small m.  We use       *)
(* immediate Rule (->) rather than RuleDelayed (:>) so that Module-    *)
(* local symbols don't leak into the rule RHS.                         *)

pellCoeffs[2, k_Integer] := Module[{e},
  e = Expand[(3 + 2 Sqrt[2])^k];
  {e /. Sqrt[2] -> 0, Coefficient[e, Sqrt[2]]}];
pellCoeffs[3, k_Integer] := Module[{e},
  e = Expand[(2 + Sqrt[3])^k];
  {e /. Sqrt[3] -> 0, Coefficient[e, Sqrt[3]]}];

makePellRules[d_Integer, kMax_Integer] := Module[
  {fund, rules = {}, ab, a, b, k, kk},
  fund = If[d == 2, 3 + 2 Sqrt[2], 2 + Sqrt[3]];
  Do[
    kk = k;
    ab = pellCoeffs[d, k]; {a, b} = ab;
    AppendTo[rules, Log[a + b Sqrt[d]] ->  kk Log[fund]];
    AppendTo[rules, Log[a - b Sqrt[d]] -> -kk Log[fund]],
    {k, 1, kMax}];
  rules];

makePellScaledRules[d_Integer, kMax_Integer, mMax_Integer] := Module[
  {fund, rules = {}, ab, a, b, k, m, scale, kk, mm},
  fund = If[d == 2, 3 + 2 Sqrt[2], 2 + Sqrt[3]];
  Do[
    ab = pellCoeffs[d, k]; {a, b} = ab;
    kk = k;
    Do[
      mm = m;
      scale = 2^m;
      AppendTo[rules,
        Log[scale a + scale b Sqrt[d]] -> mm Log[2] +  kk Log[fund]];
      AppendTo[rules,
        Log[scale a - scale b Sqrt[d]] -> mm Log[2] + -kk Log[fund]],
      {m, 1, mMax}],
    {k, 1, kMax}];
  rules];

pellRules3       = makePellRules[3, 40];
pellRules3Scaled = makePellScaledRules[3, 24, 10];
pellRules2       = makePellRules[2, 20];
pellRules2Scaled = makePellScaledRules[2, 12, 6];

pellMiscRules = {
  Log[-1 + Sqrt[3]]  -> Log[2] - Log[1 + Sqrt[3]],
  Log[4 - 2 Sqrt[3]] -> Log[2] - Log[2 + Sqrt[3]],
  Log[4 + 2 Sqrt[3]] -> Log[2] + Log[2 + Sqrt[3]]
};

applyPell[expr_] := expr //. Join[
  pellRules3, pellRules3Scaled,
  pellRules2, pellRules2Scaled,
  pellMiscRules];

(* K1at via linearity on the tent factor. *)
K1at[p_Integer, q_Integer, r_Integer] := K1at[p, q, r] = Sum[
  (-1)^(a + b + c) Mp[p + a, q + b, r + c],
  {a, 0, 1}, {b, 0, 1}, {c, 0, 1}
];

(* K3 via IBP reduction to 2D symbolic integrals (same scheme as
   CubeGalerkin27.wl Section 4 -- proven to give exact closed forms).
   IBP on u_1 with box weight (1-u_1):
     K3diag[p,q,r] = (p+1) K1at[p,q,r] - residual2D[p+1,q,r]
     K3off[p,q,r]  = p K1at[p-1,q+1,r] + K3offRes2D[p,q+1,r]  (p>=1)
     K3off[0,q,r]  = K3offRes2D[0,q+1,r]
   where u1RadInt[k] is the 1D integral of u1^k/|u| du1 and
   residual2D / K3offRes2D are the 2D integrals over (u2,u3).    *)

ClearAll[u1RadInt, residual2D, K3offRes2D];

u1RadInt[k_Integer] := u1RadInt[k] = Integrate[
  u1^k / Sqrt[u1^2 + u2^2 + u3^2], {u1, 0, 1},
  Assumptions -> u2 > 0 && u2 < 1 && u3 > 0 && u3 < 1
];

residual2D[k_Integer, q_Integer, r_Integer] :=
  residual2D[k, q, r] = Integrate[
    (1 - u2) (1 - u3) u2^q u3^r u1RadInt[k],
    {u2, 0, 1}, {u3, 0, 1}
  ];

K3diag[p_Integer, q_Integer, r_Integer] :=
  K3diag[p, q, r] = (p + 1) K1at[p, q, r] - residual2D[p + 1, q, r];

K3offRes2D[0, Q_Integer, r_Integer] :=
  K3offRes2D[0, Q, r] = Integrate[
    (1 - u2) (1 - u3) u2^Q u3^r (1/Sqrt[u2^2 + u3^2] -
       ArcSinh[1/Sqrt[u2^2 + u3^2]]),
    {u2, 0, 1}, {u3, 0, 1}
  ];

K3offRes2D[p_Integer, Q_Integer, r_Integer] /; p >= 1 :=
  K3offRes2D[p, Q, r] = -Integrate[
    (1 - u2) (1 - u3) u2^Q u3^r u1RadInt[p],
    {u2, 0, 1}, {u3, 0, 1}
  ];

K3off[p_Integer, q_Integer, r_Integer] :=
  K3off[p, q, r] = If[p == 0,
    K3offRes2D[0, q + 1, r],
    p K1at[p - 1, q + 1, r] + K3offRes2D[p, q + 1, r]
  ];

(* Dispatch by (i,j) using cubic symmetry. *)
K3kernel[{p_, q_, r_}, i_, j_] := K3kernel[{p, q, r}, i, j] = Which[
  i == 1 && j == 1, K3diag[p, q, r],
  i == 2 && j == 2, K3diag[q, p, r],
  i == 3 && j == 3, K3diag[r, q, p],
  (i == 1 && j == 2) || (i == 2 && j == 1), K3off[p, q, r],
  (i == 1 && j == 3) || (i == 3 && j == 1), K3off[p, r, q],
  (i == 2 && j == 3) || (i == 3 && j == 2), K3off[q, r, p],
  True, $Failed
];\
\>", "Input",
 InitializationCell->True]

}, Open]],

Cell[CellGroupData[{

Cell["3. T_27 basis (9 T_9 modes + 18 quadratic modes)", "Section"],

Cell["\<\
basisT9 = {
  {1, 0, 0}, {0, 1, 0}, {0, 0, 1},                    (* constants    *)
  {r1, 0, 0}, {0, r2, 0}, {0, 0, r3},                 (* axial strain *)
  {0, r3/2, r2/2}, {r3/2, 0, r1/2}, {r2/2, r1/2, 0}   (* shear strain *)
};

quadMonomials = {r1^2, r2^2, r3^2, r2*r3, r1*r3, r1*r2};
unitVec[1] = {1, 0, 0};
unitVec[2] = {0, 1, 0};
unitVec[3] = {0, 0, 1};
basisT27quad = Flatten[
  Table[q * unitVec[k], {k, 1, 3}, {q, quadMonomials}],
  1
];
basisT27 = Join[basisT9, basisT27quad];\
\>", "Input",
 InitializationCell->True]

}, Open]],

Cell[CellGroupData[{

Cell["4. Body-bilinear assembly (bbBodyAB, b27entry)", "Section"],

Cell["\<\
kernelParity[pIdx_Integer, qIdx_Integer] :=
  Mod[
    {KroneckerDelta[pIdx, 1] + KroneckerDelta[qIdx, 1],
     KroneckerDelta[pIdx, 2] + KroneckerDelta[qIdx, 2],
     KroneckerDelta[pIdx, 3] + KroneckerDelta[qIdx, 3]},
    2
  ];

parityOK[exps_List, kp_List] :=
  AllTrue[Range[3], EvenQ[exps[[#]] + kp[[#]]] &];

ClearAll[u1, u2, u3, bbBodyAB];

bbBodyAB[poly_, pIdx_Integer, qIdx_Integer] :=
  Module[{coeffs, aPiece, bPiece, kpA = {0, 0, 0}, kpB},
    kpB = kernelParity[pIdx, qIdx];
    coeffs = CoefficientRules[Expand[poly], {u1, u2, u3}];
    aPiece = Sum[
      If[parityOK[pair[[1]], kpA],
        pair[[2]] K1at @@ pair[[1]],
        0],
      {pair, coeffs}
    ];
    bPiece = Sum[
      If[parityOK[pair[[1]], kpB],
        pair[[2]] K3kernel[pair[[1]], pIdx, qIdx],
        0],
      {pair, coeffs}
    ];
    {aPiece, bPiece}
  ];

ClearAll[xiMonInt, intXiThenSub, basisAtR, basisAtRprime, polyToTentResidual];

xiMonInt[k1_Integer, k2_Integer, k3_Integer] :=
  If[OddQ[k1] || OddQ[k2] || OddQ[k3],
    0,
    Times @@ MapThread[
      (2 (1 - #1)^(#2 + 1) / (#2 + 1)) &,
      {{u1, u2, u3}, {k1, k2, k3}}
    ]
  ];

intXiThenSub[expr_] := Module[{e, coeffs},
  e = Expand[expr];
  coeffs = CoefficientRules[e, {xi[1], xi[2], xi[3]}];
  Expand[
    Sum[pair[[2]] xiMonInt @@ pair[[1]], {pair, coeffs}] /.
      {s[1] -> 2 u1, s[2] -> 2 u2, s[3] -> 2 u3}
  ]
];

basisAtR[v_] := v /. {r1 -> xi[1] + s[1]/2, r2 -> xi[2] + s[2]/2,
   r3 -> xi[3] + s[3]/2};
basisAtRprime[v_] := v /. {r1 -> xi[1] - s[1]/2, r2 -> xi[2] - s[2]/2,
   r3 -> xi[3] - s[3]/2};

polyToTentResidual[poly_] := Expand[Cancel[
  poly / ((1 - u1) (1 - u2) (1 - u3))
]];

ClearAll[b27pairContribution, b27entry];

b27pairContribution[i_Integer, j_Integer, p_Integer, q_Integer] :=
  Module[{phiI, phiJ, productPQ, weight, residual},
    phiI = basisAtR[basisT27[[i]]][[p]];
    phiJ = basisAtRprime[basisT27[[j]]][[q]];
    productPQ = Expand[phiI phiJ];
    If[productPQ === 0, Return[{0, 0}]];
    weight = intXiThenSub[productPQ];
    residual = polyToTentResidual[weight];
    bbBodyAB[residual, p, q]
  ];

b27entry[i_Integer, j_Integer] := Module[{a = 0, b = 0, contr},
  Do[
    contr = b27pairContribution[i, j, p, q];
    If[p == q, a = a + contr[[1]]];
    b = b + contr[[2]],
    {p, 3}, {q, 3}
  ];
  32 (Aelas a + Belas b)
];\
\>", "Input",
 InitializationCell->True]

}, Open]],

Cell[CellGroupData[{

Cell["5. The 14 nonzero orbit representatives", "Section"],

Cell["\<\
(* Global indices 10..27 of basisT27 are the 18 quadratic modes:
     i = 10,11,12,13,14,15 -> k=1 (e_x), m=1..6
     i = 16,17,18,19,20,21 -> k=2 (e_y), m=1..6
     i = 22,23,24,25,26,27 -> k=3 (e_z), m=1..6
   where m=1,2,3 => S-type (r_m^2) and m=4,5,6 => X-type (cross). *)

orbits = {
  (* Within-direction (k_i = k_j) nonzero orbits *)
  {\"SSdiag_matched\",    10, 10,  3, \"alpha1_beta1\"},
  {\"SSdiag_unmatched\",  11, 11,  6, \"alpha1_beta2\"},
  {\"SSoff_onematch\",    10, 11, 12, \"alpha2_beta3\"},
  {\"SSoff_nomatches\",   11, 12,  6, \"alpha2_beta4\"},
  {\"XXdiag_typeI\",      13, 13,  3, \"alpha3_beta5\"},
  {\"XXdiag_typeII\",     14, 14,  6, \"alpha3_beta6\"},
  (* Cross-direction (k_i != k_j) nonzero orbits (A = 0 for all) *)
  {\"SXcross_typeI\",     11, 17, 12, \"zero_beta7\"},
  {\"SScross_typeIa\",    10, 17,  6, \"zero_beta8a\"},
  {\"SScross_typeIb\",    11, 16,  6, \"zero_beta8b\"},
  {\"XXcross_typeI\",     14, 26,  6, \"zero_beta8c\"},
  {\"XXcross_typeII\",    13, 20,  6, \"zero_beta9a\"},
  {\"XXcross_typeIII\",   14, 19,  6, \"zero_beta9b\"},
  {\"SXcross_typeII\",    10, 21, 12, \"zero_beta10a\"},
  {\"SXcross_typeIII\",   11, 21, 12, \"zero_beta10b\"}
};

Print[\"Orbit list loaded: \", Length[orbits], \" representative pairs.\"];
Print[];\
\>", "Input",
 InitializationCell->True]

}, Open]],

Cell[CellGroupData[{

Cell["6. Smoke test: b27entry[1,1] against closed-form reference", "Section"],

Cell["\<\
(* Primes the caches for Mp[0,0,0], Mp[1,0,0], Mp[1,1,0], Mp[1,1,1] and
   K3diag[0,0,0] at high precision, and confirms the assembly agrees
   with the exact displacement diagonal 256*(A*iA + B*iB11). *)

Print[\"Smoke test: b27entry[1,1] vs 256*(A*iA + B*iB11) ...\"];
t0 = AbsoluteTime[];
iA         = Mp[0, 0, 0] - 3 Mp[1, 0, 0] + 3 Mp[1, 1, 0] - Mp[1, 1, 1];
iB11val    = K3diag[0, 0, 0];
expect11   = 256 (Aelas iA + Belas iB11val);
got11      = b27entry[1, 1];
smokeA     = N[(got11 - expect11) /. {Aelas -> 1, Belas -> 0}, highWP];
smokeB     = N[(got11 - expect11) /. {Aelas -> 0, Belas -> 1}, highWP];
smokeTime  = AbsoluteTime[] - t0;
Print[\"  smoke test completed in \", Round[smokeTime, 0.01], \" s\"];
Print[\"  A-channel residual: \", smokeA];
Print[\"  B-channel residual: \", smokeB];
Print[\"  (both should be < 10^-\", highWP - 5, \")\"];
Print[\"  Mp[0,0,0]    = \", N[Mp[0, 0, 0],    highWP]];
Print[\"  K3diag[0,0,0]= \", N[K3diag[0, 0, 0], highWP]];
Print[];\
\>", "Input",
 InitializationCell->True]

}, Open]],

Cell[CellGroupData[{

Cell["6b. Symbolic capture helpers", "Section"],

Cell["\<\
(* Every entry returned by b27entry[i,j] is an EXACT symbolic expression
   built from Mp[], K3diag[], K3off[] values that were themselves produced
   by Integrate[] (symbolic closed form).  We capture both channels' raw
   symbolic form and a FullSimplify-ed 'tidy' form before the numerical
   N[] collapse. *)

(* Per-orbit time budget for FullSimplify on each channel. *)
symbolicTimeBudget = 180;

captureSymbolic[raw_] := Module[
  {aRaw, bRaw, aPell, bPell, aTidy, bTidy},
  aRaw  = raw /. {Aelas -> 1, Belas -> 0};
  bRaw  = raw /. {Aelas -> 0, Belas -> 1};
  (* Apply Pell rewrites BEFORE FullSimplify so Simplify sees compact logs. *)
  aPell = applyPell[aRaw];
  bPell = applyPell[bRaw];
  aTidy = TimeConstrained[FullSimplify[aPell], symbolicTimeBudget, aPell];
  bTidy = TimeConstrained[FullSimplify[bPell], symbolicTimeBudget, bPell];
  (* Re-apply: FullSimplify may have re-expanded (2+Sqrt[3])^k logs. *)
  aTidy = applyPell[aTidy];
  bTidy = applyPell[bTidy];
  {aRaw, bRaw, aTidy, bTidy}
];\
\>", "Input",
 InitializationCell->True]

}, Open]],

Cell[CellGroupData[{

Cell["7. Main loop: compute each orbit, log, checkpoint", "Section"],

Cell["\<\
Print[\"================================================================\"];
Print[\"BEGIN main loop : \", Length[orbits], \" orbits at WP=\", highWP];
Print[\"(symbolic FullSimplify budget per channel: \",
      symbolicTimeBudget, \" s)\"];
Print[\"================================================================\"];
Print[];

results = <||>;

writeCheckpoint[results_] := Module[{keys, lines},
  keys = Keys[results];
  lines = Map[
    Function[k,
      Module[{r = results[k]},
        ToString[k] <> \" -> <|\" <>
        \"\\\"i\\\" -> \"       <> ToString[r[\"i\"]]  <> \", \" <>
        \"\\\"j\\\" -> \"       <> ToString[r[\"j\"]]  <> \", \" <>
        \"\\\"tag\\\" -> \\\"\"  <> r[\"tag\"] <> \"\\\", \" <>
        \"\\\"mult\\\" -> \"    <> ToString[r[\"mult\"]] <> \", \" <>
        \"\\\"aVal\\\" -> \"    <> ToString[FullForm[r[\"aVal\"]]] <> \", \" <>
        \"\\\"bVal\\\" -> \"    <> ToString[FullForm[r[\"bVal\"]]] <> \", \" <>
        \"\\\"aSymRaw\\\" -> \" <> ToString[FullForm[r[\"aSymRaw\"]]] <> \", \" <>
        \"\\\"bSymRaw\\\" -> \" <> ToString[FullForm[r[\"bSymRaw\"]]] <> \", \" <>
        \"\\\"aSym\\\" -> \"    <> ToString[FullForm[r[\"aSym\"]]] <> \", \" <>
        \"\\\"bSym\\\" -> \"    <> ToString[FullForm[r[\"bSym\"]]] <> \", \" <>
        \"\\\"timeSec\\\" -> \" <> ToString[N[r[\"timeSec\"]]] <>
        \"|>\"
      ]
    ],
    keys
  ];
  Export[
    checkpointPath,
    \"(* CubeT6ScalarValues_HighPrec_checkpoint.wl -- partial progress. *)\\n\" <>
    \"(* Auto-generated; do not edit by hand.                          *)\\n\" <>
    \"(* Completed orbits: \" <> ToString[Length[keys]] <> \"/\" <>
      ToString[Length[orbits]] <> \"                                 *)\\n\" <>
    \"(* Last update: \" <> DateString[] <> \"                         *)\\n\\n\" <>
    \"cubeT6HighPrecResults = <|\\n  \" <>
    StringRiffle[lines, \",\\n  \"] <> \"\\n|>;\\n\",
    \"Text\"
  ];
];

Do[
  Module[{tag, i, j, mult, label, t0orb, raw,
          aSymRaw, bSymRaw, aSym, bSym, aVal, bVal, tElapsed,
          tSymStart, tSymElapsed},
    {tag, i, j, mult, label} = orb;
    Print[\"----------------------------------------------------------------\"];
    Print[\"Orbit \", tag, \"  (\", label, \")  i=\", i, \", j=\", j,
          \"  mult=\", mult];
    Print[\"  start: \", DateString[]];
    t0orb = AbsoluteTime[];
    raw   = b27entry[i, j];
    Print[\"  raw LeafCount=\", LeafCount[raw]];
    tSymStart = AbsoluteTime[];
    {aSymRaw, bSymRaw, aSym, bSym} = captureSymbolic[raw];
    tSymElapsed = AbsoluteTime[] - tSymStart;
    aVal = N[aSym, highWP];
    bVal = N[bSym, highWP];
    tElapsed = AbsoluteTime[] - t0orb;
    Print[\"  FullSimplify: \", Round[tSymElapsed, 0.01], \" s\",
          \" (A LeafCount \", LeafCount[aSymRaw], \" -> \", LeafCount[aSym],
          \", B LeafCount \", LeafCount[bSymRaw], \" -> \", LeafCount[bSym], \")\"];
    Print[\"  A numeric  = \", aVal];
    Print[\"  B numeric  = \", bVal];
    Print[\"  A symbolic = \", aSym];
    Print[\"  B symbolic = \", bSym];
    Print[\"  A TeXForm  : \", TeXForm[aSym]];
    Print[\"  B TeXForm  : \", TeXForm[bSym]];
    Print[\"  done in \", Round[tElapsed, 0.01], \" s\"];
    results[tag] = <|
      \"i\" -> i, \"j\" -> j, \"tag\" -> label, \"mult\" -> mult,
      \"aVal\" -> aVal, \"bVal\" -> bVal,
      \"aSymRaw\" -> aSymRaw, \"bSymRaw\" -> bSymRaw,
      \"aSym\" -> aSym, \"bSym\" -> bSym,
      \"timeSec\" -> tElapsed
    |>;
    writeCheckpoint[results];
    Print[\"  checkpoint written (\", Length[results], \"/\",
      Length[orbits], \" orbits complete)\"];
  ],
  {orb, orbits}
];

Print[];
Print[\"================================================================\"];
Print[\"ALL ORBITS COMPLETE\"];
Print[\"================================================================\"];\
\>", "Input",
 InitializationCell->True]

}, Open]],

Cell[CellGroupData[{

Cell["8. Extract unique A and B scalars", "Section"],

Cell["\<\
(* For each unique nonzero numeric value, also remember the symbolic
   form of the first orbit that produced it. *)

allAvals   = Values[results][[All, Key[\"aVal\"]]];
allBvals   = Values[results][[All, Key[\"bVal\"]]];
allAsym    = Values[results][[All, Key[\"aSym\"]]];
allBsym    = Values[results][[All, Key[\"bSym\"]]];
allAsymRaw = Values[results][[All, Key[\"aSymRaw\"]]];
allBsymRaw = Values[results][[All, Key[\"bSymRaw\"]]];

(* firstUniqueWithSym[vals, syms, symsRaw]
     -> {uniqueVals, uniqueSyms, uniqueSymsRaw} filtered & sorted. *)
firstUniqueWithSym[vals_, syms_, symsRaw_] := Module[
  {idxList, keptIdx = {}, seenVals = {}, tolNear},
  tolNear = 10^(-highWP + 5);
  idxList = Range[Length[vals]];
  Do[
    If[Abs[vals[[k]]] > tolNear &&
       ! AnyTrue[seenVals, Abs[# - vals[[k]]] < tolNear &],
      AppendTo[keptIdx, k];
      AppendTo[seenVals, vals[[k]]]
    ],
    {k, idxList}
  ];
  keptIdx = SortBy[keptIdx, -vals[[#]] &];
  {vals[[keptIdx]], syms[[keptIdx]], symsRaw[[keptIdx]]}
];

{uniqueA, uniqueAsym, uniqueAsymRaw} =
  firstUniqueWithSym[allAvals, allAsym, allAsymRaw];
{uniqueB, uniqueBsym, uniqueBsymRaw} =
  firstUniqueWithSym[allBvals, allBsym, allBsymRaw];

Print[];
Print[\"Unique nonzero A-scalars (\", Length[uniqueA], \"):\"];
Do[
  Print[\"  alpha[\", i, \"] = \", uniqueA[[i]]];
  Print[\"             sym = \", uniqueAsym[[i]]];
  Print[\"         TeXForm : \", TeXForm[uniqueAsym[[i]]]],
  {i, Length[uniqueA]}
];
Print[];
Print[\"Unique nonzero B-scalars (\", Length[uniqueB], \"):\"];
Do[
  Print[\"  beta[\", i, \"]  = \", uniqueB[[i]]];
  Print[\"             sym = \", uniqueBsym[[i]]];
  Print[\"         TeXForm : \", TeXForm[uniqueBsym[[i]]]],
  {i, Length[uniqueB]}
];\
\>", "Input",
 InitializationCell->True]

}, Open]],

Cell[CellGroupData[{

Cell["9. Final export", "Section"],

Cell["\<\
(* Two files are written:
     - CubeT6ScalarValues_HighPrec.wl          : numerics + symbolics
     - CubeT6ScalarValues_HighPrec_Symbolic.wl : symbolics only (sidecar) *)

symbolicFinalPath = FileNameJoin[
  {$here, \"CubeT6ScalarValues_HighPrec_Symbolic.wl\"}];

Export[
  finalPath,
  \"(* CubeT6ScalarValues_HighPrec.wl -- high-precision scalar values *)\\n\" <>
  \"(* Auto-generated by CubeT6OvernightHighPrec.nb.                   *)\\n\" <>
  \"(* Completed: \" <> DateString[] <> \"                           *)\\n\" <>
  \"(* WorkingPrecision used: \" <> ToString[highWP] <> \"                                 *)\\n\" <>
  \"(* Each result entry stores: i, j, tag, mult, aVal, bVal,           *)\\n\" <>
  \"(*   aSymRaw, bSymRaw (exact symbolic pre-FullSimplify),            *)\\n\" <>
  \"(*   aSym, bSym     (FullSimplify-tidied symbolic), timeSec.        *)\\n\\n\" <>
  \"cubeT6HighPrecResults = \" <>
    ToString[FullForm[Normal[results]]] <> \";\\n\\n\" <>
  \"cubeT6HighPrecAlphas = \" <>
    ToString[FullForm[uniqueA]] <> \";\\n\\n\" <>
  \"cubeT6HighPrecBetas  = \" <>
    ToString[FullForm[uniqueB]] <> \";\\n\\n\" <>
  \"cubeT6HighPrecAlphasSym = \" <>
    ToString[FullForm[uniqueAsym]] <> \";\\n\\n\" <>
  \"cubeT6HighPrecBetasSym  = \" <>
    ToString[FullForm[uniqueBsym]] <> \";\\n\\n\" <>
  \"cubeT6HighPrecAlphasSymRaw = \" <>
    ToString[FullForm[uniqueAsymRaw]] <> \";\\n\\n\" <>
  \"cubeT6HighPrecBetasSymRaw  = \" <>
    ToString[FullForm[uniqueBsymRaw]] <> \";\\n\",
  \"Text\"
];

(* Human-oriented sidecar: just the symbolic forms, labelled and with
   TeXForm strings for easy copy-paste into LaTeX. *)
Module[{texAlphas, texBetas, alphaLines, betaLines},
  texAlphas = Map[ToString[TeXForm[#]] &, uniqueAsym];
  texBetas  = Map[ToString[TeXForm[#]] &, uniqueBsym];
  alphaLines = Table[
    \"  alpha[\" <> ToString[i] <> \"] = \" <>
    ToString[uniqueA[[i]]] <> \"\\n\" <>
    \"           symbolic = \" <> ToString[uniqueAsym[[i]]] <> \"\\n\" <>
    \"           TeXForm  : \" <> texAlphas[[i]],
    {i, Length[uniqueA]}
  ];
  betaLines = Table[
    \"  beta[\" <> ToString[i] <> \"]  = \" <>
    ToString[uniqueB[[i]]] <> \"\\n\" <>
    \"           symbolic = \" <> ToString[uniqueBsym[[i]]] <> \"\\n\" <>
    \"           TeXForm  : \" <> texBetas[[i]],
    {i, Length[uniqueB]}
  ];
  Export[
    symbolicFinalPath,
    \"(* CubeT6ScalarValues_HighPrec_Symbolic.wl -- analytic scalars only *)\\n\" <>
    \"(* Auto-generated by CubeT6OvernightHighPrec.nb.                    *)\\n\" <>
    \"(* Completed: \" <> DateString[] <> \"                            *)\\n\" <>
    \"(* These are the exact symbolic closed forms produced by            *)\\n\" <>
    \"(* Integrate[] during the overnight run, before any N[] collapse.   *)\\n\\n\" <>
    \"(* ---------------- HUMAN-READABLE SUMMARY ---------------- *)\\n\" <>
    \"(*\\n\" <>
    \"Unique A-scalars (\" <> ToString[Length[uniqueA]] <> \"):\\n\" <>
    StringRiffle[alphaLines, \"\\n\"] <> \"\\n\\n\" <>
    \"Unique B-scalars (\" <> ToString[Length[uniqueB]] <> \"):\\n\" <>
    StringRiffle[betaLines, \"\\n\"] <> \"\\n\" <>
    \"*)\\n\\n\" <>
    \"(* ---------------- MACHINE-READABLE DEFINITIONS ---------------- *)\\n\\n\" <>
    \"cubeT6HighPrecAlphasSym = \" <>
      ToString[FullForm[uniqueAsym]] <> \";\\n\\n\" <>
    \"cubeT6HighPrecBetasSym  = \" <>
      ToString[FullForm[uniqueBsym]] <> \";\\n\\n\" <>
    \"cubeT6HighPrecAlphasSymRaw = \" <>
      ToString[FullForm[uniqueAsymRaw]] <> \";\\n\\n\" <>
    \"cubeT6HighPrecBetasSymRaw  = \" <>
      ToString[FullForm[uniqueBsymRaw]] <> \";\\n\",
    \"Text\"
  ];
];

Print[];
Print[\"Final output written to       \", finalPath];
Print[\"Symbolic sidecar written to  \", symbolicFinalPath];\
\>", "Input",
 InitializationCell->True]

}, Open]],

Cell[CellGroupData[{

Cell["10. Symbolic summary (copy-paste friendly)", "Section"],

Cell["\<\
Print[];
Print[\"================================================================\"];
Print[\"SYMBOLIC SUMMARY (copy-paste friendly)\"];
Print[\"================================================================\"];
Print[];
Print[\"---- Unique A-scalars ----\"];
Do[
  Print[];
  Print[\"alpha[\", i, \"] numeric  = \", uniqueA[[i]]];
  Print[\"alpha[\", i, \"] symbolic = \", uniqueAsym[[i]]];
  Print[\"alpha[\", i, \"] TeXForm  :\"];
  Print[TeXForm[uniqueAsym[[i]]]],
  {i, Length[uniqueA]}
];
Print[];
Print[\"---- Unique B-scalars ----\"];
Do[
  Print[];
  Print[\"beta[\", i, \"] numeric  = \", uniqueB[[i]]];
  Print[\"beta[\", i, \"] symbolic = \", uniqueBsym[[i]]];
  Print[\"beta[\", i, \"] TeXForm  :\"];
  Print[TeXForm[uniqueBsym[[i]]]],
  {i, Length[uniqueB]}
];

Print[];
Print[\"Finish time: \", DateString[]];
Print[\"===================================================================\"];
Print[\"DONE\"];
Print[\"===================================================================\"];\
\>", "Input",
 InitializationCell->True]

}, Open]]
},
WindowSize->{1200, 900},
WindowMargins->{{Automatic, 100}, {Automatic, 50}},
FrontEndVersion->"14.0 for Mac OS X ARM (64-bit) (December 12, 2023)",
StyleDefinitions->"Default.nb"
]
(* End of Notebook Content *)
