Cell[CellGroupData[{

Cell["4. Smooth Dynamic Corrections (Tetrahedron Moments)", "Section",ExpressionUUID->"a1b2c3d4-0005-0001-0001-000000000001"],

Cell["\<\
The smooth (radiation) corrections use Taylor-expanded polynomial integrals. \
The Taylor coefficients \[Phi]_n, \[Psi]_n depend only on material properties \
(same as cube). The geometry enters only through the monomial moments:
  S\\[SubZero](m) = \[Integral]_tet r^{2m} dV
  S\\[SubOne](m) = \[Integral]_tet x\\[SubOne]\\[TwoSuperior] r^{2m} dV
  S\\[SubTwo](m) = \[Integral]_tet x\\[SubOne]\\[FourSuperior] r^{2m} dV
  S\\[Sub11](m) = \[Integral]_tet \
x\\[SubOne]\\[TwoSuperior]x\\[SubTwo]\\[TwoSuperior] r^{2m} dV

Since x is linear in barycentric coordinates, r^{2m} is polynomial, and all \
integrands are polynomials over the simplex. Mathematica\[CloseCurlyQuote]s \
Integrate gives exact rational results.\
\>", "Text",ExpressionUUID->"a1b2c3d4-0005-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell["\<\
(* === Taylor coefficients (same as cube -- material only) === *)
tetTaylorCoefficients[\[Omega]val_, \[Alpha]val_, \[Beta]val_, \[Rho]val_,
                       nTaylor_: 8] :=
  Module[{phi, psi, ikb, ika, cf, cg},
    ikb = I \[Omega]val/\[Beta]val;
    ika = I \[Omega]val/\[Alpha]val;
    cf = 1/(4 Pi \[Rho]val \[Beta]val^2);
    cg = 1/(4 Pi \[Rho]val);
    phi = Table[
      cf ikb^(2 n + 1)/(2 n + 1)!,
      {n, 0, nTaylor - 1}];
    psi = Table[
      cg (ika^(2 n + 3)/\[Alpha]val^2 - ikb^(2 n + 3)/\[Beta]val^2)/(2 n + 3)!,
      {n, 0, nTaylor - 1}];
    {phi, psi}
  ];

Print[\"tetTaylorCoefficients defined.\"];\
\>", "Input",
 CellLabel->
  "In[200]:=",ExpressionUUID->"a1b2c3d4-0005-0001-0001-000000000003"],

Cell[BoxData["\<\"tetTaylorCoefficients defined.\"\>"], "Print",
 CellChangeTimes->{3.982198892294417*^9, 3.982259905694744*^9},
 CellLabel->
  "During evaluation of \
In[200]:=",ExpressionUUID->"6a4b25a7-03f1-4ce4-a0c3-7245edbd2e3a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(* === Analytical tetrahedron moments via symbolic Integrate === *)
(* Barycentric: x = v1 + l1*(v2-v1) + l2*(v3-v1) + l3*(v4-v1) *)
(* Integration region: 0 <= l1 <= 1, 0 <= l2 <= 1-l1, 0 <= l3 <= 1-l1-l2 *)
(* Jacobian = |det[v2-v1, v3-v1, v4-v1]| = 16 for our vertices *)

tetMomentsExact[aScale_, nMax_] :=
  Module[{verts, v1, d1, d2, d3, jac, x, rsq, s0, s1, s2, s11},
    verts = aScale tetVerts;
    v1 = verts[[1]];
    d1 = verts[[2]] - v1; d2 = verts[[3]] - v1; d3 = verts[[4]] - v1;
    jac = Abs[Det[{d1, d2, d3}]];
    Print[\"Jacobian = \", jac];

    x[l1_, l2_, l3_] := v1 + l1 d1 + l2 d2 + l3 d3;
    rsq[l1_, l2_, l3_] := Expand[x[l1, l2, l3] . x[l1, l2, l3]];

    s0 = Table[0, nMax + 1]; s1 = s0; s2 = s0; s11 = s0;

    Do[
      Module[{poly = Expand[rsq[l1, l2, l3]^m]},
        s0[[m + 1]] = jac Integrate[poly,
          {l1, 0, 1}, {l2, 0, 1 - l1}, {l3, 0, 1 - l1 - l2}]//Simplify;
        s1[[m + 1]] = jac Integrate[x[l1, l2, l3][[1]]^2 poly,
          {l1, 0, 1}, {l2, 0, 1 - l1}, {l3, 0, 1 - l1 - l2}]//Simplify;
        s2[[m + 1]] = jac Integrate[x[l1, l2, l3][[1]]^4 poly,
          {l1, 0, 1}, {l2, 0, 1 - l1}, {l3, 0, 1 - l1 - l2}]//Simplify;
        s11[[m + 1]] = jac Integrate[x[l1, l2, l3][[1]]^2 x[l1, l2, \
l3][[2]]^2 poly,
          {l1, 0, 1}, {l2, 0, 1 - l1}, {l3, 0, 1 - l1 - l2}]//Simplify;
        Print[\"m=\", m, \": S0=\", s0[[m+1]], \", S1=\", s1[[m+1]],
              \", S2=\", s2[[m+1]], \", S11=\", s11[[m+1]]];
      ],
      {m, 0, nMax}];

    {s0, s1, s2, s11}
  ];

Print[\"tetMomentsExact defined (polynomial integrals \[Rule] exact \
rationals).\"];\
\>", "Input",
 CellChangeTimes->{{3.9821984664937353`*^9, 3.9821985090256567`*^9}},
 CellLabel->
  "In[204]:=",ExpressionUUID->"a1b2c3d4-0005-0001-0001-000000000004"],

Cell[BoxData["\<\"tetMomentsExact defined (polynomial integrals \[Rule] exact \
rationals).\"\>"], "Print",
 CellChangeTimes->{3.9821988922968187`*^9, 3.9822599056974792`*^9},
 CellLabel->
  "During evaluation of \
In[204]:=",ExpressionUUID->"79882cd6-efa5-4b26-ad6a-bd235b4fde74"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
(* === Compute tet moments for a=1 === *)
nMoments = 7;
Print[\"Computing exact tetrahedron moments up to m = \", nMoments, \"...\"];
{s0Tet, s1Tet, s2Tet, s11Tet} = tetMomentsExact[1, nMoments];

(* Symmetry checks *)
Print[\"\\nSymmetry check: S1/S0 should be 1/3 for T_d symmetry\"];
Do[
  If[s0Tet[[m+1]] =!= 0,
    Print[\"m=\", m, \": S1/S0 = \", s1Tet[[m+1]]/s0Tet[[m+1]],
          \" (expect 1/3)\"]
  ],
{m, 0, Min[nMoments, 4]}];

Print[\"\\nAnisotropy check: (S2 - 3*S11) should be nonzero for cubic \
anisotropy\"];
Do[
  If[s0Tet[[m+1]] =!= 0,
    Print[\"m=\", m, \": S2-3*S11 = \", s2Tet[[m+1]] - 3 s11Tet[[m+1]],
          \", S2/S11 = \", s2Tet[[m+1]]/s11Tet[[m+1]] // N]
  ],
{m, 0, Min[nMoments, 4]}];\
\>", "Input",
 CellLabel->
  "In[212]:=",ExpressionUUID->"a1b2c3d4-0005-0001-0001-000000000005"],

