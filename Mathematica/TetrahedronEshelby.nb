Cell[CellGroupData[{

Cell["3. Symmetry Analysis & Comparison", "Section",ExpressionUUID->"a1b2c3d4-0004-0001-0001-000000000001"],

Cell["\<\
A regular tetrahedron has T_d symmetry (order 24). The key question is \
whether the Eshelby tensor decomposes as:

  I_{ijkl} = A \[Delta]_{ij}\[Delta]_{kl} + B(\[Delta]_{ik}\[Delta]_{jl} + \
\[Delta]_{il}\[Delta]_{jk}) + C E_{ijkl}

where E_{ijkl} = 1 if i=j=k=l, else 0 (the cubic anisotropy tensor).

This is the cubic decomposition used for the cube. If it holds for the tet, \
the same T1, T2, T3 / amplification factor machinery applies directly.\
\>", "Text",ExpressionUUID->"a1b2c3d4-0004-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell["\<\
(* === Compare with cube and sphere Eshelby === *)
Print[\"=== Comparison with cube and sphere ===\"];

(* Cube static Eshelby (from CubeAnalytic.wl) *)
j1Cube = 2 Pi/3;
j2Cube = -2/9 (Sqrt[3] - Pi);
k1Cube = 2/9 (2 Sqrt[3] + Pi);

AcubeS = 2 (-a0 j1Cube - 3 b0 j2Cube);
BcubeS = 2 b0 (j1Cube - 3 j2Cube);
CcubeS = 6 b0 (3 j2Cube - k1Cube);

Print[\"Cube static: A = \", N[AcubeS], \",  B = \", N[BcubeS], \",  C = \", \
N[CcubeS]];
Print[\"Tet  static: A = \", N[Atet],   \",  B = \", N[Btet],   \",  C = \", \
N[Ctet]];

(* Sphere Eshelby (analytical) *)
Asphere = -(9 - 10 \[Nu])/(30 \[Mu] (1 - \[Nu]));
Bsphere = 1/(30 \[Mu] (1 - \[Nu]));

Print[\"\\nSphere: A_E = \", N[Asphere], \",  B_E = \", N[Bsphere], \",  C_E \
= 0\"];

(* Key comparison: isotropic part A + 2B *)
Print[\"\\nIsotropic combination A + 2B:\"];
Print[\"  Sphere: \", N[Asphere + 2 Bsphere]];
Print[\"  Tet:    \", N[Atet + 2 Btet]];
Print[\"  Cube:   \", N[AcubeS + 2 BcubeS]];

(* Cubic anisotropy *)
Print[\"\\nCubic anisotropy C:\"];
Print[\"  Sphere: 0\"];
Print[\"  Tet:    \", N[Ctet]];
Print[\"  Cube:   \", N[CcubeS]];
Print[\"  |C_tet/C_cube| = \", N[Abs[Ctet/CcubeS]]];\
\>", "Input",
 CellLabel->
  "In[167]:=",ExpressionUUID->"a1b2c3d4-0004-0001-0001-000000000003"],

