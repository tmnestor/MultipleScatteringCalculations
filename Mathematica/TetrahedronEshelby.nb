Cell[CellGroupData[{

Cell["5. Gamma0 and Full ABC for the Tetrahedron", "Section",ExpressionUUID->"a1b2c3d4-0006-0001-0001-000000000001"],

Cell["\<\
Assemble \[CapitalGamma]\\[SubZero] and the full A, B, C = static Eshelby + \
smooth radiation corrections, using the tetrahedron\[CloseCurlyQuote]s \
geometry (Eshelby A,B,C from Section 2, moments from Section 4).\
\>", "Text",ExpressionUUID->"a1b2c3d4-0006-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell["\<\
(* === g0 for tetrahedron: integral of 1/|x| over tet === *)
(* Integrand: 1/Sqrt[rsq] where rsq is quadratic in barycentric coords *)
(* This is NOT polynomial, but Mathematica can handle 1/Sqrt[quadratic] *)

Print[\"Computing g0_tet = \[Integral] 1/|x| dV analytically...\"];
Print[\"(3D integral of 1/Sqrt[quadratic] over simplex -- may take a \
minute)\"];

g0Tet = Module[{v1, d1, d2, d3, jac, x, rsq},
  v1 = tetVerts[[1]];
  d1 = tetVerts[[2]] - v1; d2 = tetVerts[[3]] - v1; d3 = tetVerts[[4]] - v1;
  jac = Abs[Det[{d1, d2, d3}]];
  x = v1 + l1 d1 + l2 d2 + l3 d3;
  rsq = Expand[x . x];
  jac Integrate[1/Sqrt[rsq],
    {l1, 0, 1}, {l2, 0, 1 - l1}, {l3, 0, 1 - l1 - l2}]//Simplify
];

Print[\"g0_tet = \", g0Tet];
Print[\"g0_tet (numerical) = \", N[g0Tet]];
Print[\"g0_cube = \", N[(4/3) Log[70226 + 40545 Sqrt[3]] - 2 Pi]];

(* Gamma0 static part *)
Gamma0stat = (a0 + b0/3) g0Tet;  (* for a=1 *)
Print[\"\\nGamma0_stat (tet, a=1) = \", N[Gamma0stat]];\
\>", "Input",
 CellChangeTimes->{{3.9821984259123917`*^9, 3.982198429507751*^9}},
 CellLabel->
  "In[223]:=",ExpressionUUID->"a1b2c3d4-0006-0001-0001-000000000003"],

