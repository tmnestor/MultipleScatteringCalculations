Cell[CellGroupData[{

Cell["\<\
(* === Four triangular faces with exact geometry === *)
(* Face f is opposite vertex f.  nJac = Cross[e1,e2] with outward sign. *)
(* Key insight: n_l * Jacobian = nJac[[l]], so sqrt(3) cancels exactly. *)

faceIndices = {{2, 3, 4}, {1, 4, 3}, {1, 2, 4}, {1, 3, 2}};

tetFaces = Table[
  Module[{vs, e1, e2, nJac},
    vs = tetVerts[[faceIndices[[f]]]];
    e1 = vs[[2]] - vs[[1]];
    e2 = vs[[3]] - vs[[1]];
    nJac = Cross[e1, e2];
    (* Ensure outward: face centroid . nJac > 0 *)
    If[(vs[[1]] + vs[[2]] + vs[[3]]) . nJac < 0, nJac = -nJac];
    <|\"v0\" -> vs[[1]], \"e1\" -> e1, \"e2\" -> e2, \"nJac\" -> nJac,
     \"area\" -> Sqrt[Cross[e1, e2] . Cross[e1, e2]]/2|>
  ],
  {f, 4}];

Do[
  Print[\"Face \", f, \": v0=\", tetFaces[[f]][\"v0\"],
        \", nJac=\", tetFaces[[f]][\"nJac\"],
        \", area=\", tetFaces[[f]][\"area\"]]
, {f, 4}];\
\>", "Input",
 CellLabel->"In[30]:=",ExpressionUUID->"a1b2c3d4-0002-0001-0001-000000000004"],

