Cell[CellGroupData[{

Cell["\<\
(* === Verify by computing a few off-diagonal components === *)
(* These should be zero by T_d symmetry *)
Print[\"=== Symmetry verification ===\"];

(* I_{1123}: should be 0 *)
Print[\"Computing I_{1123} (should be 0)...\"];
Ja1123 = computeJa[2, 3];
Jb1123 = computeJb[1, 1, 2, 3];
I1123 = a0 Ja1123 + b0 Jb1123;
Print[\"  I_{1123} = \", Simplify[I1123], \" (exact zero? \", I1123 === 0, \
\")\"];

(* I_{1213}: should be 0 *)
Print[\"Computing I_{1213} (should be 0)...\"];
Jb1213 = computeJb[1, 2, 1, 3];
I1213 = b0 Jb1213;
Print[\"  I_{1213} = \", Simplify[I1213], \" (exact zero? \", I1213 === 0, \
\")\"];

(* I_{2323}: should = I_{1212} = B *)
Print[\"\\nComputing I_{2323} (should = B)...\"];
Jb2323 = computeJb[2, 3, 2, 3];
I2323 = b0 Jb2323;
Print[\"  I_{2323} = \", N[I2323]];
Print[\"  I_{1212} = \", N[I1212]];
Print[\"  Equal? \", Simplify[I2323 - I1212] === 0];\
\>", "Input",
 CellLabel->
  "In[143]:=",ExpressionUUID->"a1b2c3d4-0003-0001-0001-000000000006"],

