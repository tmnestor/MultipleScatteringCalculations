Cell[CellGroupData[{

Cell["\<\
(* === Full Gamma0 and ABC at a test frequency === *)
(* Use ka = 0.05 (deep Rayleigh regime) *)
kaTest = 5/100;
\[Omega]test = kaTest \[Alpha];  (* for a=1 *)
Print[\"Test: ka = \", kaTest, \", \[Omega] = \", N[\[Omega]test], \" rad/s\"];

nTaylor = 8;
{phiTest, psiTest} = tetTaylorCoefficients[\[Omega]test, \[Alpha], \[Beta], \
\[Rho], nTaylor];

(* Gamma0 = static + smooth *)
Gamma0smooth = Total[phiTest s0Tet[[1;;nTaylor]]] + Total[psiTest \
s1Tet[[1;;nTaylor]]];
Gamma0tet = Gamma0stat + Gamma0smooth;
Print[\"Gamma0_tet = \", N[Gamma0tet]];

(* ABC smooth corrections -- same formulas as cubeABC *)
AsmTet = 0;
BsmTet = 0;
CsmTet = 0;

(* A_smooth *)
If[nTaylor > 2,
  Do[AsmTet += 4 nn (nn - 1) phiTest[[nn + 1]] s1Tet[[nn - 1]], {nn, 2, \
nTaylor - 1}];
  Do[AsmTet += 4 nn (nn - 1) psiTest[[nn + 1]] s11Tet[[nn - 1]], {nn, 2, \
nTaylor - 1}]
];
If[nTaylor > 1,
  Do[AsmTet += 2 nn phiTest[[nn + 1]] s0Tet[[nn]], {nn, 1, nTaylor - 1}];
  Do[AsmTet += 2 nn psiTest[[nn + 1]] s1Tet[[nn]], {nn, 1, nTaylor - 1}]
];

(* B_smooth *)
BsmTet = Total[psiTest s0Tet[[1;;nTaylor]]];
If[nTaylor > 1,
  Do[BsmTet += 4 nn psiTest[[nn + 1]] s1Tet[[nn]], {nn, 1, nTaylor - 1}]
];
If[nTaylor > 2,
  Do[BsmTet += 4 nn (nn - 1) psiTest[[nn + 1]] s11Tet[[nn - 1]], {nn, 2, \
nTaylor - 1}]
];

(* C_smooth *)
If[nTaylor > 2,
  Do[CsmTet += 4 nn (nn - 1) psiTest[[nn + 1]] (s2Tet[[nn - 1]] - 3 \
s11Tet[[nn - 1]]),
    {nn, 2, nTaylor - 1}]
];

AtotTet = Atet + AsmTet;
BtotTet = Btet + BsmTet;
CtotTet = Ctet + CsmTet;

Print[\"\\nFull A,B,C at ka=\", N[kaTest], \":\"];
Print[\"  A_tet = \", N[AtotTet]];
Print[\"  B_tet = \", N[BtotTet]];
Print[\"  C_tet = \", N[CtotTet]];
Print[\"  (static only: A=\", N[Atet], \", B=\", N[Btet], \", C=\", N[Ctet], \
\")\"];\
\>", "Input",
 CellLabel->
  "In[262]:=",ExpressionUUID->"a1b2c3d4-0006-0001-0001-000000000004"],

