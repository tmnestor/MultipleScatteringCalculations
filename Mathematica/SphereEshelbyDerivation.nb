Notebook[{

Cell[CellGroupData[{
Cell["Multipole Eshelby Concentration Factors via Series Expansion", "Title",ExpressionUUID->"c2bae2c0-1187-44f7-8e49-6dc16bcdad1f"],

Cell["T. M. Nestor \[Dash] Research School of Earth Sciences, ANU", "Subtitle",ExpressionUUID->"eefadc5a-55c3-40d8-b8ac-626ba63cce23"],

Cell["\<\
Derives multipole Eshelby concentration factors E_n for elastic sphere \
scattering via series expansion of the Mie boundary problem.

Three key tricks that avoid the SphericalBesselJ simplification hang:
1. sin/cos recurrence for Bessel functions (pure polynomials after Series)
2. Physical wavespeeds directly (no independent slowness variables)
3. Series[detCr/detM, ...] instead of Cancel (avoids algebraic GCD)

Non-dimensionalized: \[Mu]0 = \[Rho]0 = a = 1.
Free symbols: lam0 (=\[Lambda]0/\[Mu]0), dlam, dmu, drho.

The concentration factor relates full to Born scattering coefficients:
    a_n(full) = E_n \[CenterDot] a_n(Born)

Known results: E_0 = K_0/(K_0 + \[Alpha]_E \[CapitalDelta]K), E_1 = 1, E_2 = \
1/(1 + \[Beta]_E \[CapitalDelta]\[Mu]/\[Mu]_0).
Goal: closed-form E_3, E_4, E_5 as rational functions of elastic moduli.\
\>", "Text",ExpressionUUID->"250ee33e-d651-4988-931a-d07e35c7cae6"],

Cell[CellGroupData[{

Cell["1. Spherical Bessel Functions via sin/cos Recurrence", "Section",ExpressionUUID->"dc47353d-f041-4d80-889f-feecf727d33d"],

Cell["\<\
Define j_n, y_n, h_n^(1) using the upward recurrence from sin/cos. After \
Series expansion in the frequency variable w, these become pure polynomials \
in 1/z \[Times] {Sin[z], Cos[z]} \[LongDash] no special functions for \
Mathematica to get stuck simplifying.\
\>", "Text",ExpressionUUID->"197ebb85-b7d7-499e-8f63-4b9b7090b8ad"],

Cell[BoxData[{
 RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"jn", "[", 
    RowBox[{"0", ",", " ", "z_"}], "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"Sin", "[", "z", "]"}], "/", "z"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"jn", "[", 
    RowBox[{"1", ",", " ", "z_"}], "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Sin", "[", "z", "]"}], "/", 
     RowBox[{"z", "^", "2"}]}], " ", "-", " ", 
    RowBox[{
     RowBox[{"Cos", "[", "z", "]"}], "/", "z"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"jn", "[", 
    RowBox[{
     RowBox[{"n_Integer", " ", "/;", " ", 
      RowBox[{"n", " ", ">=", " ", "2"}]}], ",", " ", "z_"}], "]"}], " ", ":=",
    "\n", "  ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"jn", "[", 
      RowBox[{"n", ",", " ", "z"}], "]"}], " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", " ", "n"}], " ", "-", " ", "1"}], ")"}], "/", "z"}], " ", 
       RowBox[{"jn", "[", 
        RowBox[{
         RowBox[{"n", " ", "-", " ", "1"}], ",", " ", "z"}], "]"}]}], " ", "-",
       " ", 
      RowBox[{"jn", "[", 
       RowBox[{
        RowBox[{"n", " ", "-", " ", "2"}], ",", " ", "z"}], "]"}]}]}], 
    ")"}]}], ";"}]}], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"842a9b67-d479-469a-91de-3f0174c68938"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"yn", "[", 
    RowBox[{"0", ",", " ", "z_"}], "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{"Cos", "[", "z", "]"}]}], "/", "z"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"yn", "[", 
    RowBox[{"1", ",", " ", "z_"}], "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"Cos", "[", "z", "]"}]}], "/", 
     RowBox[{"z", "^", "2"}]}], " ", "-", " ", 
    RowBox[{
     RowBox[{"Sin", "[", "z", "]"}], "/", "z"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"yn", "[", 
    RowBox[{
     RowBox[{"n_Integer", " ", "/;", " ", 
      RowBox[{"n", " ", ">=", " ", "2"}]}], ",", " ", "z_"}], "]"}], " ", ":=",
    "\n", "  ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"yn", "[", 
      RowBox[{"n", ",", " ", "z"}], "]"}], " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", " ", "n"}], " ", "-", " ", "1"}], ")"}], "/", "z"}], " ", 
       RowBox[{"yn", "[", 
        RowBox[{
         RowBox[{"n", " ", "-", " ", "1"}], ",", " ", "z"}], "]"}]}], " ", "-",
       " ", 
      RowBox[{"yn", "[", 
       RowBox[{
        RowBox[{"n", " ", "-", " ", "2"}], ",", " ", "z"}], "]"}]}]}], 
    ")"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"hn", "[", 
    RowBox[{"n_", ",", " ", "z_"}], "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"jn", "[", 
     RowBox[{"n", ",", " ", "z"}], "]"}], " ", "+", " ", 
    RowBox[{"I", " ", 
     RowBox[{"yn", "[", 
      RowBox[{"n", ",", " ", "z"}], "]"}]}]}]}], ";"}]}], "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"07a3a0e9-5bef-4de1-9a71-dd4b7255bd81"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. Elastic Field Functions", "Section",ExpressionUUID->"afbb82b6-e60e-43ba-95ec-59a46d9638c9"],

Cell["\<\
P-wave and S-wave radial field functions, matching sphere_scattering.py. Each \
returns {u_r, u_\[Theta], \[Sigma]_rr, \[Sigma]_r\[Theta]} for a potential of \
the form \[Phi] = z_n(kr) P_n(cos\[Theta]).\
\>", "Text",ExpressionUUID->"be6c7470-ae3f-4ce1-b73a-a582567c1f8e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"P", "-", "wave"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"pField", "[", 
     RowBox[{
     "n_", ",", " ", "k_", ",", " ", "r_", ",", " ", "lam_", ",", " ", "mu_", 
      ",", " ", "zfn_"}], "]"}], " ", ":=", "\n", "  ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"z", " ", "=", " ", 
         RowBox[{"k", " ", "r"}]}], ",", " ", "t", ",", " ", "zv", ",", " ", 
        "zp"}], "}"}], ",", "\n", "    ", 
      RowBox[{
       RowBox[{"zv", " ", "=", " ", 
        RowBox[{
         RowBox[{"zfn", "[", 
          RowBox[{"n", ",", " ", "t"}], "]"}], " ", "/.", " ", 
         RowBox[{"t", " ", "->", " ", "z"}]}]}], ";", "\n", "    ", 
       RowBox[{"zp", " ", "=", " ", 
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"zfn", "[", 
            RowBox[{"n", ",", " ", "t"}], "]"}], ",", " ", "t"}], "]"}], " ", 
         "/.", " ", 
         RowBox[{"t", " ", "->", " ", "z"}]}]}], ";", "\n", "    ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"k", " ", "zp"}], ",", " ", 
         RowBox[{"zv", "/", "r"}], ",", "\n", "     ", 
         RowBox[{
          RowBox[{
           RowBox[{"-", 
            RowBox[{"(", 
             RowBox[{"lam", " ", "+", " ", 
              RowBox[{"2", " ", "mu"}]}], ")"}]}], " ", 
           RowBox[{"k", "^", "2"}], " ", "zv"}], " ", "-", " ", 
          RowBox[{"4", " ", "mu", " ", "k", " ", 
           RowBox[{"zp", "/", "r"}]}], " ", "+", "\n", "       ", 
          RowBox[{"2", " ", "mu", " ", 
           RowBox[{"n", " ", 
            RowBox[{"(", 
             RowBox[{"n", " ", "+", " ", "1"}], ")"}]}], " ", 
           RowBox[{"zv", "/", 
            RowBox[{"r", "^", "2"}]}]}]}], ",", "\n", "     ", 
         RowBox[{"2", " ", "mu", " ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"k", " ", "zp"}], " ", "-", " ", 
             RowBox[{"zv", "/", "r"}]}], ")"}], "/", "r"}]}]}], "}"}]}]}], 
     "]"}]}], ";"}]}]], "Input",
 CellLabel->"In[9]:=",ExpressionUUID->"355485f4-e3f1-4eab-a4b2-e0ee917b331b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"S", "-", "wave"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"sField", "[", 
     RowBox[{
     "n_", ",", " ", "k_", ",", " ", "r_", ",", " ", "mu_", ",", " ", 
      "zfn_"}], "]"}], " ", ":=", "\n", "  ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"z", " ", "=", " ", 
         RowBox[{"k", " ", "r"}]}], ",", " ", "t", ",", " ", "zv", ",", " ", 
        "zp", ",", " ", 
        RowBox[{"nn1", " ", "=", " ", 
         RowBox[{"n", " ", 
          RowBox[{"(", 
           RowBox[{"n", " ", "+", " ", "1"}], ")"}]}]}]}], "}"}], ",", "\n", 
      "    ", 
      RowBox[{
       RowBox[{"zv", " ", "=", " ", 
        RowBox[{
         RowBox[{"zfn", "[", 
          RowBox[{"n", ",", " ", "t"}], "]"}], " ", "/.", " ", 
         RowBox[{"t", " ", "->", " ", "z"}]}]}], ";", "\n", "    ", 
       RowBox[{"zp", " ", "=", " ", 
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"zfn", "[", 
            RowBox[{"n", ",", " ", "t"}], "]"}], ",", " ", "t"}], "]"}], " ", 
         "/.", " ", 
         RowBox[{"t", " ", "->", " ", "z"}]}]}], ";", "\n", "    ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"nn1", " ", 
          RowBox[{"zv", "/", "r"}]}], ",", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"zv", " ", "+", " ", 
            RowBox[{"z", " ", "zp"}]}], ")"}], "/", "r"}], ",", "\n", "     ", 
         RowBox[{"2", " ", "mu", " ", "nn1", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"k", " ", 
             RowBox[{"zp", "/", "r"}]}], " ", "-", " ", 
            RowBox[{"zv", "/", 
             RowBox[{"r", "^", "2"}]}]}], ")"}]}], ",", "\n", "     ", 
         RowBox[{"mu", " ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"2", " ", "nn1"}], " ", "-", " ", "2", " ", "-", " ", 
                
                RowBox[{"z", "^", "2"}]}], ")"}], " ", "zv"}], " ", "-", " ", 
             
             RowBox[{"2", " ", "z", " ", "zp"}]}], ")"}], "/", 
           RowBox[{"r", "^", "2"}]}]}]}], "}"}]}]}], "]"}]}], 
   ";"}]}]], "Input",
 CellLabel->"In[10]:=",ExpressionUUID->"a99e9451-2a0e-42ea-be24-b86753107a10"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. Main Derivation: deriveEn[n]", "Section",ExpressionUUID->"df278403-e436-4e94-b71d-0f2fb6ebb8eb"],

Cell["\<\
For each multipole order n, this function:
1. Builds the 2\[Times]2 (n=0) or 4\[Times]4 (n\[GreaterEqual]1) boundary \
matrix using physical wavespeeds (no independent slowness symbols)
2. Series-expands every entry in the frequency parameter w
3. Uses Cramer\[CloseCurlyQuote]s rule: a_n = Det[M_cramer]/Det[M]
4. Laurent-divides via Series[ratio] \[LongDash] no Cancel needed
5. Extracts the Born limit by \[Epsilon]-scaling contrasts only
6. Computes E_n = Limit[a_n / a_n^Born, w\[Rule]0]
7. Simplifies (30s timeout)

Key: the Sqrt wavespeed dependence on (dlam, dmu, drho) is linearized \
automatically by Series[Sqrt[...], {\[Epsilon], 0, 1}].\
\>", "Text",ExpressionUUID->"87f2ef01-6d5d-40c8-97de-0f66e90c5a56"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"deriveEn", "[", "n_Integer", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", "\n", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "w", ",", " ", "eps", ",", " ", "lami", ",", " ", "mui", ",", "\n", 
       "   ", "kPo", ",", " ", "kSo", ",", " ", "kPi", ",", " ", "kSi", ",", 
       "\n", "   ", "scP", ",", " ", "scS", ",", " ", "inP", ",", " ", "inS", 
       ",", " ", "icP", ",", "\n", "   ", "mat", ",", " ", "rhs", ",", " ", 
       "coeff", ",", " ", "matS", ",", " ", "rhsS", ",", " ", "ord", ",", 
       "\n", "   ", "cramer", ",", " ", "dM", ",", " ", "dCr", ",", " ", 
       "aSer", ",", " ", "aBorn", ",", " ", "en", ",", " ", "raw"}], "}"}], ",",
      "\n", "\n", "  ", 
     RowBox[{
      RowBox[{"ord", " ", "=", " ", 
       RowBox[{
        RowBox[{"2", " ", "n"}], " ", "+", " ", "8"}]}], ";", "\n", "  ", 
      RowBox[{"lami", " ", "=", " ", 
       RowBox[{"lam0", " ", "+", " ", "dlam"}]}], ";", "\n", "  ", 
      RowBox[{"mui", " ", "=", " ", 
       RowBox[{"1", " ", "+", " ", "dmu"}]}], ";", "\n", "\n", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Wavenumbers", " ", "with", " ", "PHYSICAL", " ", "wavespeeds"}], " ", 
       "*)"}], "\n", "  ", 
      RowBox[{"kPo", " ", "=", " ", 
       RowBox[{"w", "/", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"lam0", " ", "+", " ", "2"}], "]"}]}]}], ";", "\n", "  ", 
      RowBox[{"kSo", " ", "=", " ", "w"}], ";", "\n", "  ", 
      RowBox[{"kPi", " ", "=", " ", 
       RowBox[{"w", " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", " ", "+", " ", "drho"}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"lami", " ", "+", " ", 
            RowBox[{"2", " ", "mui"}]}], ")"}]}], "]"}]}]}], ";", "\n", "  ", 
      
      RowBox[{"kSi", " ", "=", " ", 
       RowBox[{"w", " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", " ", "+", " ", "drho"}], ")"}], "/", "mui"}], 
         "]"}]}]}], ";", "\n", "\n", "  ", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"n", " ", "==", " ", "0"}], ",", "\n", "    ", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"--", "-"}], " ", "2"}], "\[Times]", "2"}], " ", "*)"}], 
        "\n", "    ", 
        RowBox[{
         RowBox[{"scP", " ", "=", " ", 
          RowBox[{"pField", "[", 
           RowBox[{
           "0", ",", " ", "kPo", ",", " ", "1", ",", " ", "lam0", ",", " ", 
            "1", ",", " ", "hn"}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"inP", " ", "=", " ", 
          RowBox[{"pField", "[", 
           RowBox[{
           "0", ",", " ", "kPi", ",", " ", "1", ",", " ", "lami", ",", " ", 
            "mui", ",", " ", "jn"}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"icP", " ", "=", " ", 
          RowBox[{"pField", "[", 
           RowBox[{
           "0", ",", " ", "kPo", ",", " ", "1", ",", " ", "lam0", ",", " ", 
            "1", ",", " ", "jn"}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"coeff", " ", "=", " ", 
          RowBox[{"1", "/", 
           RowBox[{"(", 
            RowBox[{"I", " ", "kPo"}], ")"}]}]}], ";", "\n", "    ", 
         RowBox[{"mat", " ", "=", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"scP", "[", 
               RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
              RowBox[{"-", 
               RowBox[{"inP", "[", 
                RowBox[{"[", "1", "]"}], "]"}]}]}], "}"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"scP", "[", 
               RowBox[{"[", "3", "]"}], "]"}], ",", " ", 
              RowBox[{"-", 
               RowBox[{"inP", "[", 
                RowBox[{"[", "3", "]"}], "]"}]}]}], "}"}]}], "}"}]}], ";", 
         "\n", "    ", 
         RowBox[{"rhs", " ", "=", " ", 
          RowBox[{
           RowBox[{"-", "coeff"}], " ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"icP", "[", 
              RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
             RowBox[{"icP", "[", 
              RowBox[{"[", "3", "]"}], "]"}]}], "}"}]}]}], ";"}], "\n", 
        "    ", ",", "\n", "    ", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"--", "-"}], " ", "4"}], "\[Times]", "4"}], " ", "*)"}], 
        "\n", "    ", 
        RowBox[{
         RowBox[{"scP", " ", "=", " ", 
          RowBox[{"pField", "[", 
           RowBox[{
           "n", ",", " ", "kPo", ",", " ", "1", ",", " ", "lam0", ",", " ", 
            "1", ",", " ", "hn"}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"scS", " ", "=", " ", 
          RowBox[{"sField", "[", 
           RowBox[{
           "n", ",", " ", "kSo", ",", " ", "1", ",", " ", "1", ",", " ", 
            "hn"}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"inP", " ", "=", " ", 
          RowBox[{"pField", "[", 
           RowBox[{
           "n", ",", " ", "kPi", ",", " ", "1", ",", " ", "lami", ",", " ", 
            "mui", ",", " ", "jn"}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"inS", " ", "=", " ", 
          RowBox[{"sField", "[", 
           RowBox[{
           "n", ",", " ", "kSi", ",", " ", "1", ",", " ", "mui", ",", " ", 
            "jn"}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"icP", " ", "=", " ", 
          RowBox[{"pField", "[", 
           RowBox[{
           "n", ",", " ", "kPo", ",", " ", "1", ",", " ", "lam0", ",", " ", 
            "1", ",", " ", "jn"}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"coeff", " ", "=", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"2", " ", "n"}], " ", "+", " ", "1"}], ")"}], " ", 
            RowBox[{"I", "^", "n"}]}], "/", 
           RowBox[{"(", 
            RowBox[{"I", " ", "kPo"}], ")"}]}]}], ";", "\n", "    ", 
         RowBox[{"mat", " ", "=", " ", 
          RowBox[{"Transpose", "[", 
           RowBox[{"{", 
            RowBox[{"scP", ",", " ", "scS", ",", " ", 
             RowBox[{"-", "inP"}], ",", " ", 
             RowBox[{"-", "inS"}]}], "}"}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"rhs", " ", "=", " ", 
          RowBox[{
           RowBox[{"-", "coeff"}], " ", "icP"}]}], ";"}]}], "\n", "  ", "]"}],
       ";", "\n", "\n", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"Series", "-", "expand"}], " ", "every", " ", "matrix", " ", 
        "entry", " ", "in", " ", "w"}], " ", "*)"}], "\n", "  ", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<  [\>\"", ",", " ", "n", ",", 
        " ", "\"\<] Series expanding (ord=\>\"", ",", " ", "ord", ",", 
        " ", "\"\<)...\>\""}], "]"}], ";", "\n", "  ", 
      RowBox[{"matS", " ", "=", " ", 
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Normal", "[", 
           RowBox[{"Series", "[", 
            RowBox[{"#", ",", " ", 
             RowBox[{"{", 
              RowBox[{"w", ",", " ", "0", ",", " ", "ord"}], "}"}]}], "]"}], 
           "]"}], " ", "&"}], ",", " ", "mat", ",", " ", 
         RowBox[{"{", "2", "}"}]}], "]"}]}], ";", "\n", "  ", 
      RowBox[{"rhsS", " ", "=", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Normal", "[", 
          RowBox[{"Series", "[", 
           RowBox[{"#", ",", " ", 
            RowBox[{"{", 
             RowBox[{"w", ",", " ", "0", ",", " ", "ord"}], "}"}]}], "]"}], 
          "]"}], " ", "&"}], " ", "/@", " ", "rhs"}]}], ";", "\n", "\n", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{"Cramer", "'"}], 
       RowBox[{"s", " ", "rule"}], " ", "*)"}], "\n", "  ", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<  [\>\"", ",", " ", "n", ",", " ", "\"\<] Det (\>\"", ",",
         " ", 
        RowBox[{"Length", "[", "matS", "]"}], ",", " ", "\"\<\[Times]\>\"", ",",
         " ", 
        RowBox[{"Length", "[", "matS", "]"}], ",", " ", "\"\<)...\>\""}], 
       "]"}], ";", "\n", "  ", 
      RowBox[{"cramer", " ", "=", " ", "matS"}], ";", "\n", "  ", 
      RowBox[{
       RowBox[{"cramer", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", " ", "1"}], "]"}], "]"}], " ", "=", " ", 
       "rhsS"}], ";", "\n", "  ", 
      RowBox[{"dM", " ", "=", " ", 
       RowBox[{"Det", "[", "matS", "]"}]}], ";", "\n", "  ", 
      RowBox[{"dCr", " ", "=", " ", 
       RowBox[{"Det", "[", "cramer", "]"}]}], ";", "\n", "\n", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{"Series", " ", "of", " ", "ratio"}], " ", "*)"}], "\n", "  ", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<  [\>\"", ",", " ", "n", ",", 
        " ", "\"\<] Laurent division...\>\""}], "]"}], ";", "\n", "  ", 
      RowBox[{"aSer", " ", "=", " ", 
       RowBox[{"Normal", "[", 
        RowBox[{"Series", "[", 
         RowBox[{
          RowBox[{"dCr", "/", "dM"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"w", ",", " ", "0", ",", " ", "ord"}], "}"}]}], "]"}], 
        "]"}]}], ";", "\n", "\n", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"Born", " ", "limit"}], ":", " ", 
        RowBox[{"eps", "-", "scale", " ", "contrasts", " ", "only"}]}], " ", 
       "*)"}], "\n", "  ", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<  [\>\"", ",", " ", "n", ",", 
        " ", "\"\<] Born limit...\>\""}], "]"}], ";", "\n", "  ", 
      RowBox[{"aBorn", " ", "=", " ", 
       RowBox[{
        RowBox[{"Normal", "[", 
         RowBox[{"Series", "[", "\n", "      ", 
          RowBox[{
           RowBox[{"aSer", " ", "/.", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"dlam", " ", "->", " ", 
               RowBox[{"eps", " ", "dlam"}]}], ",", " ", 
              RowBox[{"dmu", " ", "->", " ", 
               RowBox[{"eps", " ", "dmu"}]}], ",", " ", 
              RowBox[{"drho", " ", "->", " ", 
               RowBox[{"eps", " ", "drho"}]}]}], "}"}]}], ",", "\n", "      ", 
           RowBox[{"{", 
            RowBox[{"eps", ",", " ", "0", ",", " ", "1"}], "}"}]}], "]"}], 
         "]"}], " ", "/.", " ", 
        RowBox[{"eps", " ", "->", " ", "1"}]}]}], ";", "\n", "\n", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{
        SubscriptBox["E", "n"], " ", "=", " ", 
        RowBox[{"lim", " ", 
         RowBox[{
          SubscriptBox["a", "n"], "/", 
          SubsuperscriptBox["a", "n", "Born"]}]}]}], " ", "*)"}], "\n", "  ", 
      
      RowBox[{"Print", "[", 
       RowBox[{"\"\<  [\>\"", ",", " ", "n", ",", 
        " ", "\"\<] Limit + Cancel...\>\""}], "]"}], ";", "\n", "  ", 
      RowBox[{"en", " ", "=", " ", 
       RowBox[{"Cancel", "[", 
        RowBox[{"Limit", "[", 
         RowBox[{
          RowBox[{"aSer", "/", "aBorn"}], ",", " ", 
          RowBox[{"w", " ", "->", " ", "0"}]}], "]"}], "]"}]}], ";", "\n", 
      "\n", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{"Simplify", " ", "with", " ", "30", "s", " ", "timeout"}], " ",
        "*)"}], "\n", "  ", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<  [\>\"", ",", " ", "n", ",", 
        " ", "\"\<] FullSimplify (30s timeout)...\>\""}], "]"}], ";", "\n", 
      "  ", 
      RowBox[{"raw", " ", "=", " ", "en"}], ";", "\n", "  ", 
      RowBox[{"en", " ", "=", " ", 
       RowBox[{"TimeConstrained", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"FullSimplify", "[", 
          RowBox[{"en", ",", "\n", "      ", 
           RowBox[{"Assumptions", " ", "->", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"lam0", " ", ">", " ", "0"}], ",", " ", 
              RowBox[{"dmu", " ", ">", " ", 
               RowBox[{"-", "1"}]}], ",", " ", 
              RowBox[{"drho", " ", ">", " ", 
               RowBox[{"-", "1"}]}], ",", " ", 
              RowBox[{"dlam", " ", ">", " ", 
               RowBox[{"-", "lam0"}]}]}], "}"}]}]}], "]"}], ",", "\n", "    ",
          "30", ",", " ", "raw"}], "]"}]}], ";", "\n", "  ", "en"}]}], "\n", 
    "]"}]}], ";"}]], "Input",
 CellLabel->"In[11]:=",ExpressionUUID->"00bbbd2d-2e5b-4ca1-8a7a-12ae7eee580e"]
}, Open  ]],

