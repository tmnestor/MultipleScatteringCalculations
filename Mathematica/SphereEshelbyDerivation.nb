Cell[CellGroupData[{

Cell["5. Numerical Verification", "Section",ExpressionUUID->"bc5db266-5ec9-48b1-b024-34a115991fb9"],

Cell["\<\
Substitute Python test parameters to verify against the numerical code.
\[Alpha]=5000, \[Beta]=3000, \[Rho]=2500, \
\[CapitalDelta]\[Lambda]=2\[Times]10\\[Superscript]9, \[CapitalDelta]\[Mu]=1\
\[Times]10\\[Superscript]9, \[CapitalDelta]\[Rho]=100.
Non-dimensionalized: lam0/\[Mu]0 = 7/9, dlam/\[Mu]0 = 4/45, dmu/\[Mu]0 = \
2/45, drho/\[Rho]0 = 1/25.\
\>", "Text",ExpressionUUID->"b3cd45d4-ff45-43ec-880f-18764da6f5f9"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Print", "[", "\"\<\\n===== Numerical check =====\>\"", "]"}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"testSubs", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"lam0", " ", "->", " ", 
      RowBox[{"7", "/", "9"}]}], ",", " ", 
     RowBox[{"dlam", " ", "->", " ", 
      RowBox[{"4", "/", "45"}]}], ",", " ", 
     RowBox[{"dmu", " ", "->", " ", 
      RowBox[{"2", "/", "45"}]}], ",", " ", 
     RowBox[{"drho", " ", "->", " ", 
      RowBox[{"1", "/", "25"}]}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Do", "[", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{"val", " ", "=", " ", 
      RowBox[{
       RowBox[{"results", "[", "n", "]"}], " ", "/.", " ", "testSubs"}]}], ";",
      "\n", "  ", 
     RowBox[{"Print", "[", 
      RowBox[{
       RowBox[{"Subscript", "[", 
        RowBox[{"\"\<E\>\"", ",", " ", "n"}], "]"}], ",", " ", "\"\< = \>\"", 
       ",", " ", 
       RowBox[{"N", "[", 
        RowBox[{"val", ",", " ", "10"}], "]"}]}], "]"}], ";"}], "\n", ",", 
    " ", 
    RowBox[{"{", 
     RowBox[{"n", ",", " ", "0", ",", " ", "5"}], "}"}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
  "Print", "[", "\"\<\\n===== Python reference values =====\>\"", "]"}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", "\"\<E_0 = 0.9590828991\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", "\"\<E_1 = 1.0000029890\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", "\"\<E_2 = 0.9784326389\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", "\"\<E_3 = 0.9748482740\>\"", "]"}], ";"}], "\n", 
 RowBox[{
