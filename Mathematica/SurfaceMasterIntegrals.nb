Cell["\<\
(* General IBP reduction for B-channel *)
(* For integrands with xi_a/rho^3 factor, integrate by parts in xi_a *)

(* 2D boundary integrals (face of the unit cube) *)
Bp2D[q_, r_] := NIntegrate[
  y^q z^r / Sqrt[1 + y^2 + z^2],
  {y, 0, 1}, {z, 0, 1},
  PrecisionGoal -> 15
]

(* These 2D integrals are also analytically tractable: *)
(* same structure as the v-integral but at a fixed boundary *)
Bp2DSym[q_, r_] := Integrate[
  y^q z^r / Sqrt[1 + y^2 + z^2],
  {y, 0, 1}, {z, 0, 1}
]

Print[\"2D boundary integrals:\"];
Do[
  Print[\"  Bp2D[\", q, \",\", r, \"] = \", Bp2DSym[q, r],
    \"  (N = \", N[Bp2DSym[q, r], 15], \")\"],
  {q, 0, 3}, {r, 0, 2}
]\
\>", "Input",ExpressionUUID->"cc238ae9-e62f-416c-a0e3-528bef446ebe"]
}, Open  ]],

Cell[CellGroupData[{

Cell["8. Assembly: From Master Integrals to Surface Stiffness", "Section",ExpressionUUID->"4aa305d2-1e4c-4273-b5f8-3d2ed02b223d"],

Cell["\<\
The surface stiffness for one face is assembled by:
1. Express phi_alpha(r) in (sigma, xi, v) variables
2. Express traction t(s) in (sigma, xi) variables (on face)
3. Multiply and expand into monomials of (sigma1, xi1, sigma2, xi2, v)
4. Integrate each sigma analytically: sigma^k -> (1-xi)^{k+1}/(k+1)
5. Expand (1-xi)^n and collect monomials of (xi1, xi2, v)
6. Look up each monomial coefficient * Mp[p,q,r]
7. Sum over all 6 faces

The following function automates steps 1-6 for a single face.\
\>", "Text",ExpressionUUID->"b028aa85-0f87-4aa4-a70c-b76a417dbeb4"],

Cell["\<\
(* Automated surface integral for one face, A-channel *)
(* Returns the integral as a sum of Mp values *)
surfaceA1Face[
  alphaMode_, (* {exponents, direction} for phi_alpha *)
  betaMode_,  (* {exponents, direction} for phi_beta *)
  faceAxis_,  (* which axis the face is on (1,2,3) *)
  faceSign_   (* +1 or -1 *)
] := Module[
  {r1, r2, r3, s1, s2, sig1, xi1, sig2, xi2, v,
   trac, phiAlpha, integrand, shared, normal,
   sigmaResult, expanded, result = 0},
  
  (* Identify shared and normal coordinates *)
  shared = Delete[{1, 2, 3}, faceAxis];
  normal = faceAxis;
  
  (* Mode function phi_alpha *)
  phiAlpha = ({r1, r2, r3}[[alphaMode[[2]]]])
    (r1^alphaMode[[1, 1]] r2^alphaMode[[1, 2]] r3^alphaMode[[1, 3]] /.
     {r1, r2, r3}[[alphaMode[[2]]]] -> 1);
  (* Actually, simpler: phi_alpha = product of r^n for the monomial part *)
  phiAlpha = r1^alphaMode[[1, 1]] r2^alphaMode[[1, 2]] r3^alphaMode[[1, 3]];
  
  (* Traction from beta mode on this face *)
  trac = tractionOnFace[
    betaMode[[1]], betaMode[[2]], faceAxis, faceSign, Dlam, Dmu];
  
  (* A-channel: same component coupling *)
  (* integrand = phi_alpha_i * trac_i / |r - r'| *)
  (* Only i = alphaMode[[2]] contributes *)
  integrand = phiAlpha * trac[[alphaMode[[2]]]];
  
  (* Substitute: shared coords -> (sigma, xi), normal coord -> v *)
  integrand = integrand /. {
    {r1, r2, r3}[[shared[[1]]]] -> sig1 + xi1,
    {r1, r2, r3}[[shared[[2]]]] -> sig2 + xi2,
    {r1, r2, r3}[[normal]] -> 1 - 2 v,
    {r1, r2, r3}[[shared[[1]]]] -> sig1 - xi1, (* for s coords in traction *)
    {r1, r2, r3}[[shared[[2]]]] -> sig2 - xi2
  };
  (* NOTE: The traction uses surface coords s_a = sigma_a - xi_a *)
  (* This substitution needs care -- traction was already evaluated at face \
*)
  (* so it only has the s1, s2 dependence *)
  
  (* This is a sketch -- the user should flesh out the bookkeeping *)
  (* The key point is that everything reduces to Mp integrals *)
  integrand
]\
\>", "Input",ExpressionUUID->"efd2808c-aeb0-46ae-8a86-37769c12fb8c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["9. Worked Example: T1u[1,2] A_Dlam Channel", "Section",ExpressionUUID->"5a2ade36-fe00-4386-a27f-69937ba809c1"],

Cell["\<\
Let's trace through one specific entry to validate the framework.

T1u mode 1 = constant displacement e_1 (in Usym basis)
T1u mode 2 = mix of S-type quadratics

For the A_Dlam channel: set Dmu = 0, a0 = 1, b0 = 0.
The known numerical value is 301.68 (from CubeT27Stiffness_LS.wl).\
\>", "Text",ExpressionUUID->"dc083840-4b1e-4bbf-bc4e-c0771fd92bb1"],

Cell["\<\
(* Direct numerical check: simplest case *)
(* A-channel integral of (constant e_1) with traction from r1^2 e1 *)
(* on face z = +1: traction = {0, 0, 2 Dlam s1} for r1^2 e1 *)
(* A-channel: only same-component coupling *)
(* phi_alpha = e_1 (component 1), traction component 1 = 0 *)
(* So this particular pair gives 0 on face z = +1. *)
(* Need to check face x = +1 instead: *)

Print[\"Traction of r1^2 e1 on face x=+1:\"];
Print[tractionOnFace[{2, 0, 0}, 1, 1, 1, Dlam, Dmu]];
Print[\"Traction of r1^2 e1 on face y=+1:\"];
Print[tractionOnFace[{2, 0, 0}, 1, 2, 1, Dlam, Dmu]];
Print[\"Traction of r1^2 e1 on face z=+1:\"];
Print[tractionOnFace[{2, 0, 0}, 1, 3, 1, Dlam, Dmu]];\
\>", "Input",ExpressionUUID->"1706f768-df7d-43c9-8c65-f911731498f4"],

Cell["\<\
(* Direct 5D NIntegrate for validation *)
(* Face x = +1: r' = (1, s1, s2), normal = e_1 *)
(* phi_alpha = 1 (constant, component 1) *)
(* traction of r1^2 e1 on x=+1: sigma_{k1} at r1=1 *)
(* = {2(Dlam + 2Dmu), 0, 0} *)

directTest = NIntegrate[
  1 * 2 * 1 / (4 Pi) *
  1/Sqrt[(r1 - 1)^2 + (r2 - s1)^2 + (r3 - s2)^2],
  {r1, -1, 1}, {r2, -1, 1}, {r3, -1, 1},
  {s1, -1, 1}, {s2, -1, 1},
  PrecisionGoal -> 8, MaxRecursion -> 15,
  Method -> {\"GlobalAdaptive\", \"SingularityHandler\" -> \"DuffyCoordinates\
\"}
];
Print[\"Direct 5D NIntegrate (one face, Dlam channel): \", directTest];
Print[\"This should match the contribution from face x=+1.\"];

(* Now via master integrals: *)
(* After substitution (sig2 = (r2+s1)/2, xi2 = (r2-s1)/2, etc.) *)
(* and v = (1 - r1)/2 (for face x = +1), the integrand is: *)
(* 1/(2 rho) * (Jacobian factors) *)
(* Integral = 4 * 4 * 2 * (1/2) * Mp[0,0,0] = 16 Mp[0,0,0] *)
(* (Check the prefactors carefully!) *)
Print[\"16 * Mp[0,0,0] = \", 16 * mpNumTable[{0,0,0}]];\
\>", "Input",ExpressionUUID->"624af0e3-98ec-41e3-bcd3-2e8dc8f1ef07"]
}, Open  ]],

Cell[CellGroupData[{

Cell["10. Prefactor Bookkeeping", "Section",ExpressionUUID->"9e1d8289-2323-4d4a-b486-45873b8318ea"],

Cell["\<\
The full prefactor chain for the surface A-channel integral on one face:

1. Jacobian (sigma,xi) substitution: 2 per pair, 2 pairs = 4
2. Octant symmetry: 4 per pair, 2 pairs = 16
3. v substitution: dr3 = -2 dv, factor 2
4. Green's tensor: 1/(4 pi) * a0 * 1/|x| = a0/(4 pi) * 1/(2 rho)
5. Face area element: dS = ds1 ds2 (no metric factor for flat face)

Total for A-channel on one face:
  4 (Jacobian) * 16 (octant) * 2 (v) * 1/(8 pi) (Green's)
  = 128 / (8 pi) = 16/pi

Times the polynomial coefficient from the mode/traction product.
Summed over the relevant faces (2 or 6 depending on symmetry).

IMPORTANT: The factor 1/(4 pi) comes from the Green's tensor normalization.
In CubeT27Stiffness_LS.wl, the Green's tensor was G_ij = a0/|x| delta_ij
where a0 already contains the 1/(8 pi rho alpha^2 beta^2) factor.
So the surface integrals there did NOT include 1/(4 pi) -- check carefully.\
\>", "Text",ExpressionUUID->"69af3e33-6ca4-415b-b93e-693f9400e272"],

Cell["\<\
(* Verify prefactors against known numerical value *)
(* The user should trace through one complete example *)
(* to nail down the prefactor convention. *)

(* Hint: the CubeT27Stiffness_LS.wl Green's tensor was: *)
(*   G_ij(x) = (a0/|x|) delta_ij + (b0/|x|^3) x_i x_j *)
(* with a0, b0 set to 1 for the channel decomposition. *)
(* So the surface integral is just: *)
(*   Integral phi_i(r) * (1/|r-r'|) * t_i(r') dV(r) dS(r') *)
(* with no 4pi factors. *)\
\>", "Input",ExpressionUUID->"c0fa594c-e212-4220-8fd4-d2faa256c918"]
}, Open  ]],

Cell[CellGroupData[{

Cell["11. Complete Analytical Reduction", "Section",ExpressionUUID->"9c10c9bf-5785-4abe-bf59-39588495c96b"],

Cell["\<\
Once all Mp values are computed symbolically, the surface stiffness
matrix entries are LINEAR COMBINATIONS of Mp values with RATIONAL
coefficients (from the polynomial expansion and sigma integration).

This means the final answers are closed-form expressions involving
the same special functions as the body bilinear: ArcTan, Log, Sqrt
of algebraic numbers.

The B-channel additionally involves 2D boundary integrals Bp2D[q,r]
from the integration by parts, which are also expressible in terms
of ArcTan, Log, Sqrt.\
\>", "Text",ExpressionUUID->"d6311b1e-5821-4042-bbe0-e4c22079ac15"],

Cell["\<\
(* ================================================================ *)
(* EXERCISE: Compute all 31 needed Mp values symbolically, *)
(* then assemble the full surface stiffness for each irrep. *)
(* Compare with CubeT27Stiffness_LS.wl numerical values. *)
(* ================================================================ *)

(* Known values from CubeT27Stiffness_LS.wl (numerical, ~10 digits): *)
knownT1u = {
  (* Surface stiffness, A_Dlam channel, T1u 4x4 *)
  {1,2} -> 301.680440020328,
  {1,3} -> 0,
  {1,4} -> 301.680440020328,
  {2,2} -> 109.18507257344282,
  {2,3} -> 0,
  {2,4} -> 109.18507257344282,
  {3,2} -> 187.0285709919309,
  {3,3} -> 0,
  {3,4} -> 187.0285709919309,
  {4,2} -> 284.24440209695274,
  {4,3} -> 0,
  {4,4} -> 284.24440209695274
};
Print[\"Target values for validation:\"];
Scan[Print[\"  T1u[\", #[[1]], \"] A_Dlam = \", #[[2]]] &, knownT1u];\
\>", "Input",ExpressionUUID->"6209cad3-2f7f-4930-99cf-583773b5392a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["12. Summary", "Section",ExpressionUUID->"5b0a07f7-a4e7-4043-a065-816b97c283f9"],

Cell["\<\
The surface master integrals for the cube LS-convolved stiffness
reduce to the SAME family Mp[p,q,r] as the body bilinear, via:

1. (sigma, xi) substitution for the 2 shared coordinates
2. v = (1-r_normal)/2 for the face-normal coordinate
3. Sigma integrals factor out analytically
4. Everything reduces to Mp[p,q,r] = Int_[0,1]^3 x^p y^q z^r / rho
5. B-channel reduces via IBP: xi/rho^3 = -d(1/rho)/d(xi)

Needed: 31 unique Mp values (p >= q >= r, max index 4).
Many are already known from the body computation.
The rest are computed by Mathematica's Integrate in seconds to minutes.

The final surface stiffness entries are rational linear combinations
of these Mp values -- giving fully analytical, closed-form results.\
\>", "Text",ExpressionUUID->"19214dbd-2cdf-406c-833a-288a875a538d"],

