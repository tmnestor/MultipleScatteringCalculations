Cell[CellGroupData[{

Cell["11. Voxelization Visualization", "Section",ExpressionUUID->"a1b00012-0001-0001-0001-000000000001"],

Cell["\<\
Show the voxelized sphere with cube centres and the bounding sphere for \
reference.\
\>", "Text",ExpressionUUID->"a1b00012-0001-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "3", "D", " ", "visualization", " ", "of", " ", "voxelized", " ", 
    "sphere"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"cubeGraphics", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Cuboid", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"cubeCentres", "[", 
           RowBox[{"[", "i", "]"}], "]"}], " ", "-", " ", 
          RowBox[{
           RowBox[{"d", "/", "2"}], " ", 
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "1", ",", " ", "1"}], "}"}]}]}], ",", "\n",
          "         ", 
         RowBox[{
          RowBox[{"cubeCentres", "[", 
           RowBox[{"[", "i", "]"}], "]"}], " ", "+", " ", 
          RowBox[{
           RowBox[{"d", "/", "2"}], " ", 
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "1", ",", " ", "1"}], "}"}]}]}]}], "]"}], ",",
        "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", "nCubes"}], "}"}]}], "\n", "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"pltVoxels", " ", "=", " ", 
     RowBox[{"Graphics3D", "[", 
      RowBox[{
       RowBox[{"{", "\n", "  ", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"EdgeForm", "[", 
            RowBox[{"{", 
             RowBox[{"Thin", ",", " ", "Gray"}], "}"}], "]"}], ",", " ", 
           RowBox[{"FaceForm", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Opacity", "[", "0.3", "]"}], ",", " ", "Orange"}], 
             "}"}], "]"}], ",", "\n", "   ", "cubeGraphics"}], "}"}], ",", 
         "\n", "  ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Opacity", "[", "0.1", "]"}], ",", " ", 
           RowBox[{"Sphere", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", " ", "0", ",", " ", "0"}], "}"}], ",", " ", 
             "aRadius"}], "]"}]}], "}"}]}], "\n", "  ", "}"}], ",", "\n", 
       "  ", 
       RowBox[{"Boxed", " ", "->", " ", "True"}], ",", "\n", "  ", 
       RowBox[{"BoxRatios", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "1", ",", " ", "1"}], "}"}]}], ",", "\n", 
       "  ", 
       RowBox[{"AxesLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<z (km)\>\"", ",", " ", "\"\<x (km)\>\"", ",", 
          " ", "\"\<y (km)\>\""}], "}"}]}], ",", "\n", "  ", 
       RowBox[{"Axes", " ", "->", " ", "True"}], ",", "\n", "  ", 
       RowBox[{"PlotLabel", " ", "->", " ", 
        RowBox[{"\"\<Voxelized Sphere (\>\"", " ", "<>", " ", 
         RowBox[{"ToString", "[", "nCubes", "]"}], " ", "<>", 
         " ", "\"\< cubes)\>\""}]}], ",", "\n", "  ", 
       RowBox[{"ImageSize", " ", "->", " ", "500"}], ",", "\n", "  ", 
       RowBox[{"ViewPoint", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"2.5", ",", " ", "2.0", ",", " ", "1.5"}], "}"}]}]}], "\n", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "pltVoxels", "]"}], ";"}], "\n"}]}]], "Input",
 CellLabel->
  "In[183]:=",ExpressionUUID->"a1b00012-0001-0001-0001-000000000003"],

