Cell[CellGroupData[{

Cell["9. Mie Reference Solution", "Section",ExpressionUUID->"a1b00010-0001-0001-0001-000000000001"],

Cell["\<\
Evaluate the exact Mie far-field P-wave amplitude on the same angular grid \
for direct comparison.\
\>", "Text",ExpressionUUID->"a1b00010-0001-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Mie", " ", "far"}], "-", 
    RowBox[{
    "field", " ", "P", " ", "amplitude", " ", "at", " ", "same", " ", 
     "angles"}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "The", " ", "Mie", " ", "amplitude", " ", "is", " ", "defined", " ", "as", 
    " ", 
    RowBox[{"u", "^", 
     RowBox[{"scat", " ", "~", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"e", "^", 
         RowBox[{"{", "ikr", "}"}]}], "/", "r"}], ")"}]}]}], " ", "f", 
    RowBox[{"(", "theta", ")"}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"So", " ", "R", " ", "*", " ", 
    RowBox[{"u", "^", 
     RowBox[{
      RowBox[{"scat_r", " ", "~", " ", "e"}], "^", 
      RowBox[{"{", "ikR", "}"}]}]}], " ", "f", 
    RowBox[{"(", "theta", ")"}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "We", " ", "need", " ", "the", " ", "same", " ", "normalisation", " ", 
    "for", " ", "comparison"}], " ", "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"mieAmplitude", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"th", ",", " ", "fP", ",", " ", "kPv"}], "}"}], ",", "\n", 
         "    ", 
         RowBox[{
          RowBox[{"th", " ", "=", " ", 
           RowBox[{"thetaGrid", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"kPv", " ", "=", " ", 
           RowBox[{"omega", "/", "alphaBg"}]}], ";", "\n", "    ", 
          RowBox[{"fP", " ", "=", " ", 
           RowBox[{"mieFarFieldP", "[", 
            RowBox[{"th", ",", " ", "mie"}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{
            "Include", " ", "phase", " ", "factor", " ", "to", " ", "match", " ",
