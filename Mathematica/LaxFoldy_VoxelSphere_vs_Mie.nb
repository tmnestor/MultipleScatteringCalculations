             RowBox[{"180", "/", "Pi"}]}], ",", " ", 
            RowBox[{"Re", "[", "lfAmplitude", "]"}]}], "}"}], "]"}], ",",
         "\n", "    ", 
         RowBox[{"PlotStyle", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"Thick", ",", " ", "Red", ",", " ", "Dashed"}], "}"}]}], ",",
          "\n", "    ", 
         RowBox[{"PlotLegends", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"\"\<Lax-Foldy 9x9 (\>\"", " ", "<>", " ", 
            RowBox[{"ToString", "[", "nCubes", "]"}], " ", "<>", 
            " ", "\"\< cubes)\>\""}], "}"}]}]}], "\n", "  ", "]"}], ",", "\n",
        "  ", 
       RowBox[{"FrameLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<Scattering angle \[Theta] (deg)\>\"", ",", "\n", 
          "    ", "\"\<Re[f_P]\>\""}], "}"}]}], ",",
        "\n", "  ", 
       RowBox[{
       "PlotLabel", " ", "->", 
        " ", "\"\<P-Wave Re[f_P]: 9x9 Lax-Foldy vs Mie\>\""}], ",",
