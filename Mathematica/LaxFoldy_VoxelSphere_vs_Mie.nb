Cell[CellGroupData[{

Cell["2. Mie Far-Field Amplitude", "Section",ExpressionUUID->"a1b00003-0001-0001-0001-000000000001"],

Cell["\<\
The P-wave far-field scattering amplitude in the direction \[Theta] (angle \
from incident P-wave propagation, i.e. from +z axis) is:
  f_P(\[Theta]) = \[CapitalSigma]_n a_n (-i)^n P_n(cos \[Theta])

We evaluate this on a grid of observation points in the z\[Dash]x plane.\
\>", "Text",ExpressionUUID->"a1b00003-0001-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"P", "-", 
    RowBox[{"wave", " ", "far"}], "-", 
    RowBox[{
    "field", " ", "amplitude", " ", "from", " ", "Mie", " ", 
     "coefficients"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"mieFarFieldP", "[", 
      RowBox[{"theta_", ",", " ", "mieCoeffs_"}], "]"}], " ", ":=", " ", 
     RowBox[{"Module", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"nMax", ",", " ", "an", ",", " ", "result"}], "}"}], ",", 
       "\n", "  ", 
       RowBox[{
        RowBox[{"nMax", " ", "=", " ", 
         RowBox[{"mieCoeffs", "[", "\"\<nMax\>\"", "]"}]}], ";", "\n", "  ", 
        RowBox[{"an", " ", "=", " ", 
         RowBox[{"mieCoeffs", "[", "\"\<a\>\"", "]"}]}], ";", "\n", "  ", 
        RowBox[{"result", " ", "=", " ", 
         RowBox[{"Sum", "[", "\n", "    ", 
          RowBox[{
           RowBox[{
            RowBox[{"an", "[", 
             RowBox[{"[", 
              RowBox[{"n", " ", "+", " ", "1"}], "]"}], "]"}], " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"-", "I"}], ")"}], "^", "n"}], " ", 
            RowBox[{"LegendreP", "[", 
             RowBox[{"n", ",", " ", 
              RowBox[{"Cos", "[", "theta", "]"}]}], "]"}]}], ",", "\n", 
           "    ", 
           RowBox[{"{", 
            RowBox[{"n", ",", " ", "0", ",", " ", "nMax"}], "}"}]}], "\n", 
          "  ", "]"}]}], ";", "\n", "  ", "result"}]}], "\n", "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Full", " ", "scattered", " ", "P"}], "-", 
     RowBox[{
     "wave", " ", "displacement", " ", "in", " ", "far", " ", "field"}]}], 
    " ", "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"u", "^", "scat_P"}], 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"r", ",", " ", "\[Theta]"}], ")"}], " ", "~", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"e", "^", 
         RowBox[{"{", "ikr", "}"}]}], "/", "r"}], ")"}]}], " ", "f_P", 
     RowBox[{"(", "\[Theta]", ")"}], " ", 
     RowBox[{"\\[", "HAT", "]"}], "r"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"mieScatteredP", "[", 
      RowBox[{
      "r_", ",", " ", "theta_", ",", " ", "omega_", ",", " ", "alpha_", ",", 
       " ", "mieCoeffs_"}], "]"}], " ", ":=", " ", 
     RowBox[{"Module", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"kP", ",", " ", "fP"}], "}"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{"kP", " ", "=", " ", 
         RowBox[{"omega", "/", "alpha"}]}], ";", "\n", "  ", 
        RowBox[{"fP", " ", "=", " ", 
         RowBox[{"mieFarFieldP", "[", 
          RowBox[{"theta", ",", " ", "mieCoeffs"}], "]"}]}], ";", "\n", "  ", 
        
        RowBox[{"fP", " ", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "kP", " ", "r"}], "]"}], "/", "r"}]}]}]}], "\n", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Print", "[", "\"\<Mie far-field functions defined.\>\"", "]"}], 
   "\n"}]}]], "Input",
 CellLabel->"In[13]:=",ExpressionUUID->"a1b00003-0001-0001-0001-000000000003"],

Cell[BoxData["\<\"Mie far-field functions defined.\"\>"], "Print",
 CellChangeTimes->{3.981994047438353*^9, 3.98199899108496*^9},
 CellLabel->
  "During evaluation of \
In[13]:=",ExpressionUUID->"8e2447ec-a050-46a8-aaf6-e70ffd732440"]
