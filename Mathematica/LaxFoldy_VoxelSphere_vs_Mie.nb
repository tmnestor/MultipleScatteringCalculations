Cell[CellGroupData[{

Cell["12. Convergence Study", "Section",ExpressionUUID->"a1b00013-0001-0001-0001-000000000001"],

Cell["\<\
Study how the Lax\[Dash]Foldy result converges to the exact Mie solution as \
the voxel size decreases (more cubes per diameter). We measure the relative \
error in the forward scattering amplitude (\[Theta] = 0).\
\>", "Text",ExpressionUUID->"a1b00013-0001-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Convergence", " ", 
    RowBox[{"study", ":", " ", 
     RowBox[{"forward", " ", "scattering", " ", "amplitude"}]}]}], " ", 
   "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Full", " ", "9", "N", " ", "x", " ", "9", "N", " ", "Lax"}], "-", 
    RowBox[{
    "Foldy", " ", "solve", " ", "for", " ", "a", " ", "given", " ", 
     "nPerD"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"laxFoldyForwardAmplitude", "[", "nPerD_", "]"}], " ", ":=", " ", 
     RowBox[{"Module", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "dd", ",", " ", "halfG", ",", " ", "centres", ",", " ", "nC", ",",
         " ", "VC", ",", " ", "dm", ",", " ", "tMat", ",", "\n", "   ", "DCv",
          ",", " ", "g0v", ",", " ", "aU", ",", " ", "aT", ",",
          " ", "aEo", ",", " ", "aEd", ",", " ", "dlS", ",", " ", "dmSD", ",",
          " ", "dmSO", ",", " ", "drS", ",", "\n", "   ",
         "Av", ",", " ", "Bv", ",", " ", "Cv", ",", " ",
         "T1v", ",", " ", "T2v", ",", " ", "T3v", ",", "\n", "   ", "sysMat",
         ",", " ", "rhsVec", ",", " ", "excF", ",", " ",
         "srcList", ",", " ", "kPv"}], "}"}],
        ",", "\n", "\n", "  ", 
       RowBox[{
        RowBox[{"dd", " ", "=", " ", 
         RowBox[{"2", " ", 
          RowBox[{"aRadius", "/", "nPerD"}]}]}], ";", "\n", "  ", 
        RowBox[{"halfG", " ", "=", " ", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "nPerD"}], "/", "2"}], " ", "+", " ", "0.5", " ", 
              "+", " ", "i"}], ")"}], " ", "dd"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"i", ",", " ", "0", ",", " ", 
             RowBox[{"nPerD", " ", "-", " ", "1"}]}], "}"}]}], "]"}]}], ";", 
        "\n", "  ", 
        RowBox[{"centres", " ", "=", " ", 
         RowBox[{"{", "}"}]}], ";", "\n", "  ", 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{"Do", "[", 
           RowBox[{
            RowBox[{"Do", "[", "\n", "    ", 
             RowBox[{
              RowBox[{"Module", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"pos", " ", "=", " ", 
                  RowBox[{"{", 
                   RowBox[{"zz", ",", " ", "xx", ",", " ", "yy"}], "}"}]}], 
                 "}"}], ",", "\n", "      ", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"Norm", "[", "pos", "]"}], " ", "<", " ", 
                   "aRadius"}], ",", " ", 
                  RowBox[{"AppendTo", "[", 
                   RowBox[{"centres", ",", " ", "pos"}], "]"}]}], "]"}]}], 
               "\n", "    ", "]"}], ",", " ", 
              RowBox[{"{", 
               RowBox[{"yy", ",", " ", "halfG"}], "}"}]}], "]"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"xx", ",", " ", "halfG"}], "}"}]}], "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"zz", ",", " ", "halfG"}], "}"}]}], "]"}], ";", "\n", "  ", 
        RowBox[{"centres", " ", "=", " ", 
         RowBox[{"N", "[", "centres", "]"}]}], ";", "\n", "  ", 
        RowBox[{"nC", " ", "=", " ", 
         RowBox[{"Length", "[", "centres", "]"}]}], ";", "\n", "\n", "  ", 
        RowBox[{"VC", " ", "=", " ", 
         RowBox[{"dd", "^", "3"}]}], ";", "\n", "\n", "  ", 
        RowBox[{"(*", " ",
         RowBox[{
          RowBox[{"Build", " ", "local", " ", "9", "x9", " ", "T"}], "-",
          RowBox[{
          "matrix", " ", "with", " ", "analytic", " ", "cube", " ",
           "corrections"}]}], " ", "*)"}], "\n", "  ",
        RowBox[{
         RowBox[{"{",
          RowBox[{"Av", ",", " ", "Bv", ",", " ", "Cv"}], "}"}], " ", "=", " ",
         RowBox[{"cubeABC", "[",
          RowBox[{"omega", ",", " ",
           RowBox[{"dd", "/", "2"}], ",", " ", "alphaBg", ",", " ", "betaBg", ",", " ", "rhoBg"}], "]"}]}], ";", "\n", "  ",
        RowBox[{"T1v", " ", "=", " ",
         RowBox[{
          RowBox[{"Dlam", " ",
           RowBox[{"(",
            RowBox[{"Av", " ", "+", " ",
             RowBox[{"4", " ", "Bv"}], " ", "+", " ", "Cv"}], ")"}]}], " ", "+",
           " ",
          RowBox[{"2", " ", "Dmu", " ", "Bv"}]}]}], ";", "\n", "  ",
        RowBox[{"T2v", " ", "=", " ",
         RowBox[{"Dmu", " ",
          RowBox[{"(",
           RowBox[{"Av", " ", "+", " ", "Bv"}], ")"}]}]}], ";", "\n", "  ",
        RowBox[{"T3v", " ", "=", " ",
         RowBox[{"2", " ", "Dmu", " ", "Cv"}]}], ";", "\n", "\n", "  ",
        RowBox[{"g0v", " ", "=", " ",
         RowBox[{"cubeGamma0", "[",
          RowBox[{"omega", ",", " ",
           RowBox[{"dd", "/", "2"}], ",", " ", "alphaBg", ",", " ", "betaBg", ",", " ", "rhoBg"}], "]"}]}], ";", "\n", "  ", 
        RowBox[{"aU", " ", "=", " ", 
         RowBox[{"1", "/", 
          RowBox[{"(", 
           RowBox[{"1", " ", "-", " ", 
            RowBox[{
             RowBox[{"omega", "^", "2"}], " ", "Drho", " ", "g0v"}]}], 
           ")"}]}]}], ";", "\n", "  ", 
        RowBox[{"aT", " ", "=", " ", 
         RowBox[{"1", "/", 
          RowBox[{"(", 
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"3", " ", "T1v"}], " ", "-", " ", 
            RowBox[{"2", " ", "T2v"}], " ", "-", " ", "T3v"}], ")"}]}]}], ";",
         "\n", "  ", 
        RowBox[{"aEo", " ", "=", " ", 
         RowBox[{"1", "/", 
          RowBox[{"(", 
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"2", " ", "T2v"}]}], ")"}]}]}], ";", "\n", "  ", 
        RowBox[{"aEd", " ", "=", " ", 
         RowBox[{"1", "/", 
          RowBox[{"(", 
           RowBox[{"1", " ", "-", " ", 
            RowBox[{"2", " ", "T2v"}], " ", "-", " ", "T3v"}], ")"}]}]}], ";",
         "\n", "  ", 
        RowBox[{"dlS", " ", "=", " ", 
         RowBox[{
          RowBox[{"Dlam", " ", "aT"}], " ", "+", " ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"2.", "/", "3."}], ")"}], " ", "Dmu", " ", 
           RowBox[{"(", 
            RowBox[{"aT", " ", "-", " ", "aEd"}], ")"}]}]}]}], ";", "\n", 
        "  ", 
        RowBox[{"dmSD", " ", "=", " ", 
         RowBox[{"Dmu", " ", "aEd"}]}], ";", "\n", "  ", 
        RowBox[{"dmSO", " ", "=", " ", 
         RowBox[{"Dmu", " ", "aEo"}]}], ";", "\n", "  ", 
        RowBox[{"drS", " ", "=", " ", 
         RowBox[{"Drho", " ", "aU"}]}], ";", "\n", "\n", "  ", 
        RowBox[{"DCv", " ", "=", " ", 
         RowBox[{"ConstantArray", "[", 
          RowBox[{"0.", ",", " ", 
           RowBox[{"{", 
            RowBox[{"6", ",", " ", "6"}], "}"}]}], "]"}]}], ";", "\n", "  ", 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"DCv", "[", 
            RowBox[{"[", 
             RowBox[{"ii", ",", " ", "ii"}], "]"}], "]"}], " ", "=", " ", 
           RowBox[{"2", " ", "dmSD"}]}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"ii", ",", " ", "3"}], "}"}]}], "]"}], ";", "\n", "  ", 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"DCv", "[", 
            RowBox[{"[", 
             RowBox[{"ii", ",", " ", "ii"}], "]"}], "]"}], " ", "=", " ", 
           RowBox[{"2", " ", "dmSO"}]}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"ii", ",", " ", "4", ",", " ", "6"}], "}"}]}], "]"}], ";", 
        "\n", "  ", 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{"Do", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"DCv", "[", 
              RowBox[{"[", 
               RowBox[{"ii", ",", " ", "jj"}], "]"}], "]"}], " ", "+=", " ", 
             "dlS"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"jj", ",", " ", "3"}], "}"}]}], "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"ii", ",", " ", "3"}], "}"}]}], "]"}], ";", "\n", "\n", 
        "  ", 
        RowBox[{"tMat", " ", "=", " ", 
         RowBox[{"ConstantArray", "[", 
          RowBox[{
           RowBox[{"0.", " ", "+", " ", 
            RowBox[{"0.", " ", "I"}]}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"9", ",", " ", "9"}], "}"}]}], "]"}]}], ";", "\n", "  ", 
        RowBox[{
         RowBox[{"tMat", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"1", " ", ";;", " ", "3"}], ",", " ", 
            RowBox[{"1", " ", ";;", " ", "3"}]}], "]"}], "]"}], " ", "=", " ", 
         RowBox[{"VC", " ", 
          RowBox[{"omega", "^", "2"}], " ", "drS", " ", 
          RowBox[{"IdentityMatrix", "[", "3", "]"}]}]}], ";", "\n", "  ", 
        RowBox[{
         RowBox[{"tMat", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"4", " ", ";;", " ", "9"}], ",", " ", 
            RowBox[{"4", " ", ";;", " ", "9"}]}], "]"}], "]"}], " ", "=", " ", 
         RowBox[{"VC", " ", 
          RowBox[{"N", "[", "DCv", "]"}]}]}], ";", "\n", "\n", "  ", 
        RowBox[{"dm", " ", "=", " ", 
         RowBox[{"9", " ", "nC"}]}], ";", "\n", "  ", 
        RowBox[{"sysMat", " ", "=", " ", 
         RowBox[{
          RowBox[{"IdentityMatrix", "[", "dm", "]"}], " ", "+", " ", 
          RowBox[{"0.", " ", "I"}]}]}], ";", "\n", "  ", 
        RowBox[{"rhsVec", " ", "=", " ", 
         RowBox[{"ConstantArray", "[", 
          RowBox[{
           RowBox[{"0.", " ", "+", " ", 
            RowBox[{"0.", " ", "I"}]}], ",", " ", "dm"}], "]"}]}], ";", "\n", 
        "\n", "  ", 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{"Module", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"winc", ",", " ", "idx"}], "}"}], ",", "\n", "    ", 
            RowBox[{
             RowBox[{"idx", " ", "=", " ", 
              RowBox[{"9", " ", 
               RowBox[{"(", 
                RowBox[{"j", " ", "-", " ", "1"}], ")"}]}]}], ";", "\n", 
             "    ", 
             RowBox[{"winc", " ", "=", " ", 
              RowBox[{"incidentState", "[", 
               RowBox[{"centres", "[", 
                RowBox[{"[", "j", "]"}], "]"}], "]"}]}], ";", "\n", "    ", 
             RowBox[{"Do", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"rhsVec", "[", 
                 RowBox[{"[", 
                  RowBox[{"idx", " ", "+", " ", "ii"}], "]"}], "]"}], " ", "=",
                 " ", 
                RowBox[{"winc", "[", 
                 RowBox[{"[", "ii", "]"}], "]"}]}], ",", " ", 
               RowBox[{"{", 
                RowBox[{"ii", ",", " ", "9"}], "}"}]}], "]"}], ";"}]}], "\n", 
           "  ", "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"j", ",", " ", "nC"}], "}"}]}], "]"}], ";", "\n", "\n", 
        "  ", 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"j", " ", "!=", " ", "k"}], ",", "\n", "    ", 
            RowBox[{"Module", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
               "xjk", ",", " ", "Pjk", ",", " ", "block", ",", " ", "idxJ", ",",
                 " ", "idxK"}], "}"}], ",", "\n", "      ", 
              RowBox[{
               RowBox[{"xjk", " ", "=", " ", 
                RowBox[{
                 RowBox[{"centres", "[", 
                  RowBox[{"[", "j", "]"}], "]"}], " ", "-", " ", 
                 RowBox[{"centres", "[", 
                  RowBox[{"[", "k", "]"}], "]"}]}]}], ";", "\n", "      ", 
               RowBox[{"Pjk", " ", "=", " ", 
                RowBox[{"propagator9x9", "[", 
                 RowBox[{
                 "xjk", ",", " ", "omega", ",", " ", "alphaBg", ",", " ", 
                  "betaBg", ",", " ", "rhoBg"}], "]"}]}], ";", "\n", "      ", 
               RowBox[{"block", " ", "=", " ", 
                RowBox[{"-", 
                 RowBox[{"Pjk", " ", ".", " ", "tMat"}]}]}], ";", "\n", 
               "      ", 
               RowBox[{"idxJ", " ", "=", " ", 
                RowBox[{"9", " ", 
                 RowBox[{"(", 
                  RowBox[{"j", " ", "-", " ", "1"}], ")"}]}]}], ";", " ", 
               RowBox[{"idxK", " ", "=", " ", 
                RowBox[{"9", " ", 
                 RowBox[{"(", 
                  RowBox[{"k", " ", "-", " ", "1"}], ")"}]}]}], ";", "\n", 
               "      ", 
               RowBox[{"Do", "[", 
                RowBox[{
                 RowBox[{"Do", "[", "\n", "        ", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"sysMat", "[", 
                    RowBox[{"[", 
                    RowBox[{
                    RowBox[{"idxJ", " ", "+", " ", "ii"}], ",", " ", 
                    RowBox[{"idxK", " ", "+", " ", "jj"}]}], "]"}], "]"}], 
                    " ", "=", " ", 
                    RowBox[{"block", "[", 
                    RowBox[{"[", 
                    RowBox[{"ii", ",", " ", "jj"}], "]"}], "]"}]}], ",", "\n",
                    "        ", 
                   RowBox[{"{", 
                    RowBox[{"jj", ",", " ", "9"}], "}"}]}], "]"}], ",", " ", 
                 RowBox[{"{", 
                  RowBox[{"ii", ",", " ", "9"}], "}"}]}], "]"}], ";"}]}], 
             "\n", "    ", "]"}]}], "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"j", ",", " ", "nC"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"k", ",", " ", "nC"}], "}"}]}], "]"}], ";", "\n", "\n", 
        "  ", 
        RowBox[{"excF", " ", "=", " ", 
         RowBox[{"LinearSolve", "[", 
          RowBox[{"sysMat", ",", " ", "rhsVec"}], "]"}]}], ";", "\n", "\n", 
        "  ", 
        RowBox[{"(*", " ",
         RowBox[{"Forward", " ", "far", "-",
          RowBox[{"field", " ", "amplitude", " ",
           RowBox[{"(", "asymptotic", ")"}]}]}], " ", "*)"}], "\n", "  ",
        RowBox[{"kPv", " ", "=", " ",
         RowBox[{"omega", "/", "alphaBg"}]}], ";", "\n", "  ",
        RowBox[{"srcList", " ", "=", " ",
         RowBox[{"Table", "[",
          RowBox[{
           RowBox[{"tMat", " ", ".", " ",
            RowBox[{"excF", "[",
             RowBox[{"[",
              RowBox[{
               RowBox[{
                RowBox[{"9", " ",
                 RowBox[{"(",
                  RowBox[{"kk", " ", "-", " ", "1"}], ")"}]}], " ", "+", " ", "1"}],
               " ", ";;", " ",
               RowBox[{"9", " ", "kk"}]}], "]"}], "]"}]}], ",", " ",
           RowBox[{"{",
            RowBox[{"kk", ",", " ", "nC"}], "}"}]}], "]"}]}], ";", "\n", "\n",
        "  ",
        RowBox[{"{",
         RowBox[{"nC", ",", " ",
          RowBox[{"cubeFarFieldP", "[",
           RowBox[{"0.", ",", " ", "kPv", ",", " ", "alphaBg", ",", " ",
            "rhoBg", ",", "\n", "    ",
            "centres", ",", " ", "srcList", ",", " ",
            "voigtPairs", ",", " ", "voigtWeight"}], "]"}]}], "}"}]}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Reference", ":", " ", 
     RowBox[{"Mie", " ", "forward", " ", "amplitude"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"mieForward", " ", "=", " ",
     RowBox[{"mieFarFieldP", "[",
      RowBox[{"0.", ",", " ", "mie"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\\n--- Convergence Study: Forward Scattering ---\>\"", 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Mie reference |f(0)| = \>\"", ",", " ", 
      RowBox[{"Abs", "[", "mieForward", "]"}]}], "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Run", " ", "for", " ", "several", " ", "resolutions"}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"nPerDiamList", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"3", ",", " ", "5", ",", " ", "7"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"convergenceData", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "result", ",", " ", "nC", ",", " ", "fwd", ",", " ", "relErr"}], 
          "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"Print", "[", 
           
           RowBox[{"\"\<  nPerDiam = \>\"", ",", " ", "np", ",", 
            " ", "\"\<...\>\""}], "]"}], ";", "\n", "    ", 
          RowBox[{"result", " ", "=", " ", 
           RowBox[{"laxFoldyForwardAmplitude", "[", "np", "]"}]}], ";", "\n", 
          "    ", 
          RowBox[{"nC", " ", "=", " ", 
           RowBox[{"result", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"fwd", " ", "=", " ", 
           RowBox[{"result", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"relErr", " ", "=", " ", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"fwd", " ", "-", " ", "mieForward"}], "]"}], "/", 
            RowBox[{"Abs", "[", "mieForward", "]"}]}]}], ";", "\n", "    ", 
          RowBox[{"Print", "[", 
           
           RowBox[{"\"\<    N_cubes = \>\"", ",", " ", "nC", ",", 
            " ", "\"\<, |f_LF(0)| = \>\"", ",", " ", 
            RowBox[{"Abs", "[", "fwd", "]"}], ",", "\n", 
            "      ", "\"\<, rel error = \>\"", ",", " ", "relErr"}], "]"}], ";",
           "\n", "    ", 
          RowBox[{"{", 
           RowBox[{"np", ",", " ", "nC", ",", " ", 
            RowBox[{"Abs", "[", "fwd", "]"}], ",", " ", "relErr"}], "}"}]}]}],
         "\n", "  ", "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"np", ",", " ", "nPerDiamList"}], "}"}]}], "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\\n--- Summary ---\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"PaddedForm", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"TableForm", "[", 
        RowBox[{"convergenceData", ",", "\n", "    ", 
         RowBox[{"TableHeadings", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"None", ",", "\n", "      ", 
            RowBox[{"{", 
             
             RowBox[{"\"\<n/diam\>\"", ",", " ", "\"\<N_cubes\>\"", ",", 
              " ", "\"\<|f_LF(0)|\>\"", ",", " ", "\"\<Rel Error\>\""}], 
             "}"}]}], "}"}]}]}], "\n", "  ", "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"10", ",", " ", "6"}], "}"}]}], "\n", "]"}], "]"}], ";"}], 
   "\n"}]}]], "Input",
