Cell[CellGroupData[{

Cell["4. Exact Mie Solution", "Section",ExpressionUUID->"a1b00005-0001-0001-0001-000000000001"],

Cell["\<\
Compute the exact Mie scattering coefficients for the sphere, then evaluate \
the far-field P-wave amplitude as a function of scattering angle.\
\>", "Text",ExpressionUUID->"a1b00005-0001-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Mie", " ", "solution"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"nMax", " ", "=", " ", 
     RowBox[{"Max", "[", 
      RowBox[{"5", ",", " ", 
       RowBox[{"Ceiling", "[", 
        RowBox[{
         RowBox[{"kS", " ", "aRadius"}], " ", "+", " ", 
         RowBox[{"4", " ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"kS", " ", "aRadius"}], ")"}], "^", 
           RowBox[{"(", 
            RowBox[{"1.", "/", "3."}], ")"}]}]}], " ", "+", " ", "2"}], 
        "]"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<n_max = \>\"", ",", " ", "nMax"}], "]"}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"mie", " ", "=", " ", 
     RowBox[{"computeMieCoefficients", "[", 
      RowBox[{
      "omega", ",", " ", "aRadius", ",", "\n", "  ", "alphaBg", ",", " ", 
       "betaBg", ",", " ", "rhoBg", ",", " ", "lamBg", ",", " ", "muBg", ",", 
       "\n", "  ", "alphaIn", ",", " ", "betaIn", ",", " ", "rhoIn", ",", " ",
        "lamIn", ",", " ", "muIn", ",", " ", "nMax"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\\nMie coefficients (P-wave, a_n):\>\"", "]"}],
     ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<  a_\>\"", ",", " ", "n", ",", " ", "\"\< = \>\"", ",", 
        " ", 
        RowBox[{
         RowBox[{"mie", "[", "\"\<a\>\"", "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"n", " ", "+", " ", "1"}], "]"}], "]"}]}], "]"}], ",", "\n",
       "  ", 
      RowBox[{"{", 
       RowBox[{"n", ",", " ", "0", ",", " ", 
        RowBox[{"Min", "[", 
         RowBox[{"5", ",", " ", "nMax"}], "]"}]}], "}"}]}], "\n", "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\\nMie coefficients (S-wave, b_n):\>\"", "]"}],
     ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<  b_\>\"", ",", " ", "n", ",", " ", "\"\< = \>\"", ",", 
        " ", 
        RowBox[{
         RowBox[{"mie", "[", "\"\<b\>\"", "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"n", " ", "+", " ", "1"}], "]"}], "]"}]}], "]"}], ",", "\n",
       "  ", 
      RowBox[{"{", 
       RowBox[{"n", ",", " ", "0", ",", " ", 
        RowBox[{"Min", "[", 
         RowBox[{"5", ",", " ", "nMax"}], "]"}]}], "}"}]}], "\n", "]"}], 
    ";"}], "\n"}]}]], "Input",
 CellLabel->"In[53]:=",ExpressionUUID->"a1b00005-0001-0001-0001-000000000003"],

