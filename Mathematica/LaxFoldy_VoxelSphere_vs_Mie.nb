      RowBox[{"Amplitude", " ", "ratio"}], " ", "==="}]}], " ", "*)"}], "\n", 
   
   RowBox[{
    RowBox[{"ratioData", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
