Cell[CellGroupData[{

Cell["\<\
(* Static \[CapitalGamma]_0: volume integral of 1/r over cube *)
(* g0 = \[Integral] du dv dw/\[Sqrt](u^2+v^2+w^2) over [-1,1]^3 *)
g0cube = Integrate[1/Sqrt[u^2 + v^2 + w^2], {u, -1, 1}, {v, -1, 1}, {w, -1, \
1}];

(* \[CapitalGamma]_0^stat = a^2 (a0 + b0/3) g0 *)
\[CapitalGamma]0stat = a^2 (a0stat + b0stat/3) g0cube;

(* Combine with smooth polynomial *)
\[CapitalGamma]0 = \[CapitalGamma]0stat + \[CapitalGamma]0poly;

Print[\"\\nStatic \[CapitalGamma]_0:\"];
Print[\"g0 (cube geometric constant) = \", g0cube];
Print[\"\[CapitalGamma]_0^stat = \", \[CapitalGamma]0stat];
Print[\"\[CapitalGamma]_0^smooth = \", \[CapitalGamma]0poly];
Print[\"\[CapitalGamma]_0 (full) = \", \[CapitalGamma]0];\
\>", "Input",
 CellLabel->
  "In[126]:=",ExpressionUUID->"1f172228-6a79-4265-832b-c8e4e756c331"],

