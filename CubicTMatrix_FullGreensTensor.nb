Cell[CellGroupData[{

Cell["4. Integration of Polynomials over the Cube", "Section",ExpressionUUID->"b05746ed-6f79-42d1-b51e-2d6acf28dbb4"],

Cell[CellGroupData[{

Cell["\<\
(* Integrate polynomial over cube [-a,a]^3 *)
integrateCube[expr_] := Module[{expanded = Expand[expr], terms, result},
  If[expanded === 0, Return[0]];
  terms = If[Head[expanded] === Plus, List @@ expanded, {expanded}];
  result = Sum[
    Module[{term, coeff, p1, p2, p3},
      term = terms[[k]];
      p1 = Exponent[term, x1];
      p2 = Exponent[term, x2];
      p3 = Exponent[term, x3];
      coeff = term/(x1^p1 x2^p2 x3^p3);
      coeff cubeMoment[p1, p2, p3]],
    {k, 1, Length[terms]}];
  Simplify[result]];

Print[\"Test: Int 1 = \", integrateCube[1], \" (should be 8a^3)\"];
Print[\"Test: Int x1^2 = \", integrateCube[x1^2], \" (should be 8a^5/3)\"];\
\>", "Input",
 CellLabel->"In[73]:=",ExpressionUUID->"73a7fef0-e428-4c51-949f-7facb882da72"],

