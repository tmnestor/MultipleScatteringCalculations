Cell[CellGroupData[{

Cell["\<\
(* Extract smooth polynomial coefficients *)
(* \[Phi]_n = coeff of r^(2n+1) in f*r *)
(* \[Psi]_n = coeff of r^(2n+3) in g*r *)
nMax = Norder/2;

\[Phi]Coeffs = Table[
  Simplify[SeriesCoefficient[frSer, 2 n + 1]],
  {n, 0, nMax - 1}];

\[Psi]Coeffs = Table[
  Simplify[SeriesCoefficient[grSer, 2 n + 3]],
  {n, 0, nMax - 1}];

Print[\"\\n\[Phi] coefficients (smooth part of f):\"];
Do[Print[StringForm[\"\[Phi]_`` (r^``) = ``\", n, 2 n, \[Phi]Coeffs[[n + \
1]]]], {n, 0, nMax - 1}];

Print[\"\\n\[Psi] coefficients (smooth part of g/r^2):\"];
Do[Print[StringForm[\"\[Psi]_`` (r^``) = ``\", n, 2 n, \[Psi]Coeffs[[n + \
1]]]], {n, 0, nMax - 1}];\
\>", "Input",
 CellLabel->"In[33]:=",ExpressionUUID->"5fd6349f-268d-4a6f-8872-2839843c3a86"],

