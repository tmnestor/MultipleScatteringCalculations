Cell[CellGroupData[{

Cell["8. Self-Consistent Amplification Factors", "Section",ExpressionUUID->"b21d1fcf-27b9-4f2f-98f2-9fa7398a119d"],

Cell["\<\
The Voigt-notation T-matrix has block-diagonal structure, yielding four \
scalar amplification factors.\
\>", "Text",ExpressionUUID->"195bbec2-9010-4d61-8919-cc80a9546b59"],

Cell[CellGroupData[{

Cell["\<\
Print[\"\\n========================================\"];
Print[\"SELF-CONSISTENT AMPLIFICATION FACTORS\"];
Print[\"========================================\"];

denomTheta = Simplify[1 - 3 T1 - 2 T2 - T3];
denomEoff = Simplify[1 - 2 T2];
denomEdiag = Simplify[1 - 2 T2 - T3];

Print[\"A_u = 1/(1 - \[Omega]^2 \[CapitalDelta]\[Rho] \[CapitalGamma]_0)\"];
Print[\"\\nA_\[Theta] denominator = \", denomTheta];
Print[\"\\nA_e(off) denominator = \", denomEoff];
Print[\"\\nA_e(diag) denominator = \", denomEdiag];
Print[\"\\nNote: A_e(off) \[NotEqual] A_e(diag) because T_3 \[NotEqual] 0\"];\
\
\>", "Input",
 CellLabel->
  "In[207]:=",ExpressionUUID->"6c3a20ca-ae42-4a20-9780-a10f70581334"],

