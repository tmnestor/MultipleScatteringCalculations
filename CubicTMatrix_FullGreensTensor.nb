Cell[CellGroupData[{

Cell["\<\
(* Build polynomial representations *)
\[CapitalPhi][u_] := Sum[\[Phi]Coeffs[[n + 1]] u^n, {n, 0, nMax - 1}];
\[CapitalPsi][u_] := Sum[\[Psi]Coeffs[[n + 1]] u^n, {n, 0, nMax - 1}];

(* Smooth Green's tensor *)
Gs[i_, j_] := KroneckerDelta[i, j] \[CapitalPhi][rsq] + xx[[i]] xx[[j]] \
\[CapitalPsi][rsq];

Print[\"\\n\[CapitalPhi](u) = \", \[CapitalPhi][u]];
Print[\"\\n\[CapitalPsi](u) = \", \[CapitalPsi][u]];\
\>", "Input",
 CellLabel->"In[47]:=",ExpressionUUID->"c1067351-045e-4ac8-ba6d-8b30db895dad"],

