Cell[CellGroupData[{

Cell["7. T-Matrix Coupling Coefficients", "Section",ExpressionUUID->"3401a8e1-d5a7-4eaf-a1cc-102f3590d4a5"],

Cell["\<\
T_mnlp = Sum_jk S_mnjk Dc_jklp, where S is the symmetrised integral tensor \
and Dc is the isotropic stiffness contrast.\
\>", "Text",ExpressionUUID->"3306857f-4e39-4654-8a48-6db5beaa9732"],

Cell[CellGroupData[{

Cell["\<\
(* Integral tensor from A, B, C *)
Itens[i_, j_, k_, l_] :=
  Ac KroneckerDelta[i, j] KroneckerDelta[k, l] +
  Bc (KroneckerDelta[i, k] KroneckerDelta[j, l] +
      KroneckerDelta[i, l] KroneckerDelta[j, k]) +
  Cc KroneckerDelta[i, j] KroneckerDelta[j, k] KroneckerDelta[k, l];

(* Symmetrised tensor *)
Stens[m_, n_, j_, k_] := (Itens[m, j, k, n] + Itens[n, j, k, m])/2;

(* Stiffness contrast *)
Dctens[j_, k_, l_, p_] :=
  \[CapitalDelta]\[Lambda] KroneckerDelta[j, k] KroneckerDelta[l, p] +
  \[CapitalDelta]\[Mu] (KroneckerDelta[j, l] KroneckerDelta[k, p] +
                          KroneckerDelta[j, p] KroneckerDelta[k, l]);

(* T tensor *)
Ttens[m_, n_, l_, p_] := Sum[Stens[m, n, j, k] Dctens[j, k, l, p], {j, 1, 3}, \
{k, 1, 3}];

(* Independent components *)
TT1111 = Simplify[Ttens[1, 1, 1, 1]];
TT1122 = Simplify[Ttens[1, 1, 2, 2]];
TT1212 = Simplify[Ttens[1, 2, 1, 2]];

(* Decomposition *)
T1 = TT1122;
T2 = TT1212;
T3 = Simplify[TT1111 - TT1122 - 2 TT1212];

Print[\"\\n========================================\"];
Print[\"T-MATRIX COEFFICIENTS\"];
Print[\"========================================\"];
Print[\"T_1 (volumetric) = \", T1];
Print[\"T_2 (shear) = \", T2];
Print[\"T_3 (cubic anisotropy) = \", T3];\
\>", "Input",
 CellLabel->
  "In[179]:=",ExpressionUUID->"a874f462-0b3b-4a2d-b0b5-0185bffae3e0"],

