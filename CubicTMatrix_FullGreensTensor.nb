Cell[CellGroupData[{

Cell["9. Effective Material Contrasts", "Section",ExpressionUUID->"efaf31c2-e1dc-490f-a5f9-023f1b157139"],

Cell[CellGroupData[{

Cell["\<\
Print[\"\\n========================================\"];
Print[\"EFFECTIVE MATERIAL CONTRASTS\"];
Print[\"========================================\"];
Print[\"\\n\[CapitalDelta]\[Rho]* = \[CapitalDelta]\[Rho] \[CenterDot] \
A_u\"];
Print[\"\[CapitalDelta]\[Mu]*_off = \[CapitalDelta]\[Mu] / (1 - 2T_2)\"];
Print[\"\[CapitalDelta]\[Mu]*_diag = \[CapitalDelta]\[Mu] / (1 - 2T_2 - \
T_3)\"];
Print[\"\[CapitalDelta]\[Lambda]* = (\[CapitalDelta]\[Lambda] + 2\
\[CapitalDelta]\[Mu]/3) A_\[Theta] - \[CapitalDelta]\[Mu]/3 (A_e(diag) + \
A_e(off))\"];
Print[\"\\nCubic anisotropy: \[CapitalDelta]\[Mu]*_diag - \
\[CapitalDelta]\[Mu]*_off = \[CapitalDelta]\[Mu] T_3 / [(1-2T_2)(1-2T_2-T_3)]\
\"];\
\>", "Input",
